# Copy to staging.tfvars and fill in. SECRETS are NOT set here — pass them as
# TF_VAR_do_token / TF_VAR_tailscale_auth_key / TF_VAR_ghcr_token /
# TF_VAR_secret_key_base via env (CI: GitHub Actions secrets). This file holds
# only non-secret configuration and may be committed as an example.
environment          = "staging"
region               = "nyc3"
droplet_size         = "s-2vcpu-4gb"
image_ref            = "ghcr.io/tadasant/zimmer:latest"
# The staging box is Tailscale-only (no public app ingress; the deploy health-checks
# it over `tailscale ssh zimmer-staging`), so a public DNS A record is NOT required.
# Leave `domain` empty to skip DNS. Only set it (e.g. "staging.zimmer.tadasant.com")
# once that parent zone (zimmer.tadasant.com) is a DigitalOcean-managed DNS domain —
# otherwise `terraform apply` fails with "domain not found" (404).
domain               = ""
ghcr_username        = "tadasant"
ssh_key_fingerprints = [] # e.g. ["aa:bb:cc:..."] — DO-registered SSH key fingerprints
# Staging deliberately runs a throwaway Postgres container on the droplet: it is
# destroyed nightly and holds nothing worth keeping. Leaving
# managed_db_cluster_name empty selects that compose `db` service. Production sets
# it to a Managed Postgres cluster so the DB survives droplet re-creation.
managed_db_cluster_name = ""
