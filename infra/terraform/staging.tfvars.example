# Copy to staging.tfvars and fill in. SECRETS are NOT set here -- pass them as
# TF_VAR_do_token / TF_VAR_tailscale_auth_key / TF_VAR_deploy_ssh_pubkey via env
# (CI: GitHub Actions secrets). This file holds only non-secret configuration and
# may be committed as an example.
#
# The app image, env, and data stores are NOT configured here anymore -- Kamal owns
# them (config/deploy.staging.yml). Terraform only provisions the persistent host.
environment          = "staging"
region               = "nyc3"
droplet_size         = "s-2vcpu-4gb"
ssh_key_fingerprints = [] # DO-registered SSH key fingerprints. Leave EMPTY: this argument is
# ForceNew on the droplet, so adding one here makes the deploy workflow's auto-approved
# `terraform apply` destroy and recreate the box without reaping the tailnet node. Authorize
# operator keys through admin_ssh_pubkeys below instead -- it rides cloud-init, which is under
# `ignore_changes`, so it can never force-replace the droplet.

# Admin/tooling SSH public keys authorized for root, on top of the Kamal deploy key.
# cloud-init appends them to /root/.ssh/authorized_keys, and they are reachable ONLY over
# the tailnet on :2222 (real OpenSSH; tailnet :22 is Tailscale SSH, which ignores publickey).
#
# Put the public key(s) your operators and tooling (e.g. an SSH-based MCP server)
# use to reach the box here. This list is STAGING'S ONLY: production's key list lives in
# the private companion repo (zimmer/admin_authorized_keys.pub) and is converged by its
# own workflow. Nothing in THIS repo authorizes a key on production.
#
# That split is deliberate, and the two lists are NOT meant to match -- see below.
#
# FORKING / SELF-HOSTING: replace the keys below with YOUR OWN. A public key is not a
# secret, but leaving someone else's here authorizes them for root on your droplet, so
# this MUST be set per environment (never as a module default).
#
# `zimmer-production-operator` is the identity ZIMMER'S OWN AGENT SESSIONS hold: the
# private half rides Kamal's env.secret as ZIMMER_OPERATOR_SSH_KEY, and
# OperatorSshKeyProvisioner writes it to ~/.ssh/zimmer_operator_ed25519 in the container.
# Authorizing it here is what makes an ssh-* MCP server in a session able to reach this box.
#
# It takes effect on the NEXT droplet creation only -- cloud-init runs once, and the
# droplet's lifecycle block ignores user_data changes -- so a live box also needs the key
# appended to /root/.ssh/authorized_keys by hand. See docs/operate/ssh-access.md.
# It is deliberately a SEPARATE keypair from the Kamal deploy key and from the
# orchestrator's key, so it can be revoked on its own by deleting this one line.
#
# THE OPERATOR KEY IS AUTHORIZED HERE (STAGING) AND DELIBERATELY *NOT* ON PRODUCTION.
# The sessions that hold it RUN ON production, and this key is root. A session with root on
# its own host can stop the containers or wipe the catalog out from under the service that
# is executing it -- self-inflicted, and unrecoverable from inside. Root on production is
# reserved for humans (break-glass) and for the orchestrator that reaches in from a
# SEPARATE host, which survives to repair what it breaks. Staging is disposable, so the
# same key here costs a rebuild at worst -- and reaching staging is the point.
#
# If you are "fixing" a drift between this list and production's: don't. The ONE mismatch
# that is a control is that the operator key above is here and NOT on production -- never
# reconcile *that*. See docs/operate/ssh-access.md#who-is-authorized-where.
#
# `root@local` is the maintainer's LAPTOP KEY -- a human's key, break-glass only. It is the
# opposite case from the operator key: a person off-box, not a session on-box, so it is root
# on production too (that is the recovery path of last resort). Authorizing it on staging as
# well is not reconciling the control above -- it just gives the same human the same
# independent OpenSSH-on-:2222 door into staging, for when the tailnet identity path (:22)
# is the thing that is broken. A public key is not a secret; forks replace all three.
admin_ssh_pubkeys = [
  "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIFEp3tk5RCh76zPddFcoyY01MazsyHnacqo0KrAczCY6 zimmer-production-operator",
  "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIEmRanTTxADIQWHp9PZqOAFQX2SVXibTqVXb0D3AtuiU agent-orchestrator-prod-hetzner",
  "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAINtfKYBq3IWBflQJ8lXNhfgJAmS6RynvC2A1m0eFy3Zn root@local",
]

# Custom-domain HTTPS over the tailnet: turns on the Caddy TLS terminator on :443,
# fronting kamal-proxy. The cert and the `domain -> tailnet IP` A record are managed
# by the `domain-cert-staging` workflow (ACME DNS-01 via Cloudflare), NOT Terraform.
domain = "staging.zimmer.tadasant.com"

# Staging runs its own throwaway Postgres accessory via Kamal, so no managed cluster.
# Production sets this to a Managed Postgres cluster name so the DB survives rebuilds.
managed_db_cluster_name = ""
