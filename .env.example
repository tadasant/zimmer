# Rails Environment
RAILS_ENV=development

# Database Configuration (PostgreSQL)
# DATABASE_HOST=localhost
# DATABASE_PORT=5450
# DATABASE_USERNAME=your_username
# DATABASE_PASSWORD=your_password

# Web Server Configuration
# Number of Puma workers (defaults to available CPU cores)
# WEB_CONCURRENCY=2

# Redis Configuration (required for caching)
# REDIS_URL=redis://localhost:6379

# GoodJob Configuration (background job processing)
# Number of worker threads (default: 20)
# GOOD_JOB_MAX_THREADS=20

# Server PID file location (optional)
# PIDFILE=tmp/pids/server.pid

# Anthropic API Configuration
# Required for Claude Code agent to function
# Get your API key from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_api_key_here

# CLI Tool Authentication
# These tokens enable the CLI tools to authenticate without interactive login

# GitHub CLI (gh) - Used for GitHub operations
# Authenticate via OAuth device flow: run `gh auth login` inside the container.
# The OAuth token is stored in ~/.config/gh and shared via volume mount.

# Fly.io API token (used by fly-io MCP server and flyctl CLI)
# Generate at: https://fly.io/user/personal_access_tokens
# FLY_IO_API_TOKEN=your_flyio_token_here

# Note: Claude Code CLI uses OAuth authentication
# Run `claude /login` inside the Docker container to authenticate

# MCP (Model Context Protocol) Server Configuration
# MCP servers can be configured in config/mcp.json
# Each server entry specifies command, args, and env variables

# 1Password MCP Server
# Service account token for 1Password CLI access
# Create at: https://developer.1password.com/docs/service-accounts/
# OP_SERVICE_ACCOUNT_TOKEN=ops_your_service_account_token_here

# Pulse Sub-Registry MCP Server
# API credentials for browsing the PulseMCP Sub-Registry
# PULSEMCP_SUBREGISTRY_API_KEY=your_api_key_here
# PULSEMCP_SUBREGISTRY_TENANT_ID=your_tenant_id_here
# SHOW_ADMIN_TOOLS=true  # Enable admin tools (e.g., switch_tenant_id)

# Git Clone Configuration
# Agent clones are stored in ~/.agent-orchestrator/clones/ (global location)
# Bare git repositories are stored in tmp/repos/ (relative to Rails root)
# REPO_BASE_PATH=tmp/repos

# Logging
# Set log level: debug, info, warn, error, fatal
# RAILS_LOG_LEVEL=info

# Security
# Generate with: bin/rails secret
# SECRET_KEY_BASE=your_secret_key_here

# API Authentication
# Comma-separated list of valid API keys for the REST API *and* for Zimmer's
# native MCP server at POST /mcp (X-API-Key header, or Authorization: Bearer).
# Generate secure keys with: bin/rails runner "puts SecureRandom.hex(32)"
# API_KEYS=key1,key2,key3

# Self-orchestration: where a session's auto-injected MCP servers point
# Zimmer injects its own MCP server (streamable HTTP, <BASE_URL>/mcp) into every
# session it prepares, so the agent can archive itself, schedule wake-ups, and
# spawn subagent sessions. These say which instance that is and which key to use.
# The API key must be one of API_KEYS above; production and staging deploys derive
# it from the first entry automatically (see config/deploy.*.yml).
#
# Local dev (defaults to http://localhost:${PORT:-3000} and no key, which will 401):
# AGENT_ORCHESTRATOR_LOCAL_BASE_URL=http://localhost:3000
# AGENT_ORCHESTRATOR_LOCAL_API_KEY=key1
#
# Staging / production (set by the deploy, not by hand):
# AGENT_ORCHESTRATOR_STAGING_BASE_URL=https://staging.zimmer.example.com
# AGENT_ORCHESTRATOR_STAGING_API_KEY=...
# AGENT_ORCHESTRATOR_PROD_BASE_URL=https://zimmer.example.com
# AGENT_ORCHESTRATOR_PROD_API_KEY=...
