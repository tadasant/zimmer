# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*
!/.env.example

# Ignore secrets files.
/.secrets
!/.secrets.example
/secrets.json
!/secrets.json.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage files.
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets
.byebug_history

# Ignore master key for decrypting credentials and more.
/config/master.key

# Ignore application configuration
/config/application.yml

# Kamal destination-specific deploy configs are committed (deploy.staging.yml, deploy.production.yml).
# The base deploy.yml is also committed. All use ERB for host IPs from environment variables.

/app/assets/builds/*
!/app/assets/builds/.keep

/config/credentials/development.key
/config/credentials/staging.key
/config/credentials/production.key
/config/credentials/test.key

# Zimmer injects .claude/ into each session clone at prepare time (skills, hooks,
# .mcp.json, ${SECRET} substitutions). It is runtime state, never source — do not
# commit it. Every skill Zimmer ships, generic or Zimmer-specific, lives in the
# top-level AIR catalog (skills/, references/, …) and is copied in from there.
.claude/
node_modules/

# Runtime stderr capture from the Claude Code harness
claude_stderr.log

# MCP configuration (may contain API keys)
.mcp.json
# Copied from agents/mcp-servers/mcp.json at Docker build time
config/mcp.json
vendor/bundle/

# Agent container runtime logs
.logs/

# Local npm cache populated at runtime by npx invocations (tarball blobs,
# integrity manifests, and transitive package-lock.json files). Environment-
# specific — not useful to commit, and tracked contents trigger spurious
# Dependabot PRs on the nested package-lock.json files.
.npm-cache/
/vendor/bundle

# Terraform local state / provider cache
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
