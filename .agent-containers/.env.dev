# Environment for the containerized Zimmer dev stack (docker-compose.dev.yml).
#
# This file is COMMITTED and contains NO real secrets — only the wiring that
# points the app at the compose-managed Postgres and Redis. Anything sensitive
# (ANTHROPIC_API_KEY, GH tokens, RAILS_MASTER_KEY) comes in through the mounted
# ~/.claude / ~/.config/gh credentials or is set by you at runtime, never here.

RAILS_ENV=development

# --- Postgres (the `db` service) ---
# config/database.yml reads these discrete vars, NOT a single DATABASE_URL.
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_USERNAME=app
DATABASE_PASSWORD=password
# The compose Postgres speaks plaintext; don't attempt TLS negotiation.
DATABASE_SSLMODE=disable

# --- Redis (the `redis` service) ---
REDIS_URL=redis://redis:6379/0

# Bind the Rails server to all interfaces so the published host port reaches it.
BINDING=0.0.0.0
