<div id="elicitation_<%= elicitation.id %>" class="bg-amber-50 border border-amber-300 rounded-lg shadow-md mx-4 mb-3"
     data-controller="elicitation-form"
     data-elicitation-form-respond-url-value="<%= respond_elicitation_path(elicitation) %>"
     data-elicitation-form-schema-value="<%= elicitation.requested_schema.to_json %>">
  <div class="px-4 py-3">
    <%# Header with icon and tool name %>
    <div class="flex items-start gap-3">
      <div class="flex-shrink-0 mt-0.5">
        <svg class="h-5 w-5 text-amber-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 mb-1">
          <h3 class="text-sm font-semibold text-amber-900">Action Approval Required</h3>
          <% if elicitation.tool_name.present? %>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-amber-200 text-amber-800">
              <%= elicitation.tool_name %>
            </span>
          <% end %>
        </div>
        <p class="text-sm text-amber-800 mb-2"><%= elicitation.message %></p>

        <% if elicitation.context.present? %>
          <p class="text-xs text-amber-700 mb-2 italic"><%= elicitation.context %></p>
        <% end %>

        <%# Dynamic form fields from requested_schema %>
        <% schema = elicitation.requested_schema %>
        <% if schema["properties"].present? %>
          <div class="space-y-2 mb-3" data-elicitation-form-target="fieldsContainer">
            <% schema["properties"].each do |field_name, field_schema| %>
              <div class="flex flex-col">
                <label class="text-xs font-medium text-amber-900 mb-1" for="elicitation_field_<%= elicitation.id %>_<%= field_name %>">
                  <%= field_schema["title"] || field_name.humanize %>
                  <% if schema.dig("required")&.include?(field_name) %>
                    <span class="text-red-600">*</span>
                  <% end %>
                </label>
                <% if field_schema["description"].present? %>
                  <p class="text-xs text-amber-700 mb-1"><%= field_schema["description"] %></p>
                <% end %>

                <% case field_schema["type"] %>
                <% when "boolean" %>
                  <label class="inline-flex items-center">
                    <input type="checkbox"
                           id="elicitation_field_<%= elicitation.id %>_<%= field_name %>"
                           data-elicitation-form-target="field"
                           data-field-name="<%= field_name %>"
                           data-field-type="boolean"
                           class="rounded border-amber-400 text-amber-600 focus:ring-amber-500">
                    <span class="ml-2 text-sm text-amber-800">Yes</span>
                  </label>
                <% when "string" %>
                  <% if field_schema["enum"].present? %>
                    <select id="elicitation_field_<%= elicitation.id %>_<%= field_name %>"
                            data-elicitation-form-target="field"
                            data-field-name="<%= field_name %>"
                            data-field-type="string"
                            class="rounded-md border-amber-300 text-sm focus:border-amber-500 focus:ring-amber-500 px-3 py-2 pr-8">
                      <option value="">Select...</option>
                      <% field_schema["enum"].each do |opt| %>
                        <option value="<%= opt %>"><%= opt %></option>
                      <% end %>
                    </select>
                  <% else %>
                    <input type="text"
                           id="elicitation_field_<%= elicitation.id %>_<%= field_name %>"
                           data-elicitation-form-target="field"
                           data-field-name="<%= field_name %>"
                           data-field-type="string"
                           placeholder="<%= field_schema['default'] %>"
                           class="rounded-md border-amber-300 text-sm focus:border-amber-500 focus:ring-amber-500 px-3 py-2">
                  <% end %>
                <% when "number", "integer" %>
                  <input type="number"
                         id="elicitation_field_<%= elicitation.id %>_<%= field_name %>"
                         data-elicitation-form-target="field"
                         data-field-name="<%= field_name %>"
                         data-field-type="<%= field_schema['type'] %>"
                         placeholder="<%= field_schema['default'] %>"
                         class="rounded-md border-amber-300 text-sm focus:border-amber-500 focus:ring-amber-500 px-3 py-2">
                <% else %>
                  <input type="text"
                         id="elicitation_field_<%= elicitation.id %>_<%= field_name %>"
                         data-elicitation-form-target="field"
                         data-field-name="<%= field_name %>"
                         data-field-type="string"
                         class="rounded-md border-amber-300 text-sm focus:border-amber-500 focus:ring-amber-500 px-3 py-2">
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <%# Action buttons %>
        <div class="flex items-center gap-2">
          <button type="button"
                  data-action="click->elicitation-form#accept"
                  data-elicitation-form-target="acceptButton"
                  class="inline-flex items-center px-3 py-1.5 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
            <svg class="mr-1.5 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            Accept
          </button>
          <button type="button"
                  data-action="click->elicitation-form#decline"
                  data-elicitation-form-target="declineButton"
                  class="inline-flex items-center px-3 py-1.5 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-amber-500">
            <svg class="mr-1.5 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
            Decline
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
