<div class="max-w-md mx-auto mt-16 p-6">
  <div class="bg-red-50 border border-red-200 rounded-lg p-6">
    <div class="flex items-center mb-4">
      <svg class="w-6 h-6 text-red-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
      </svg>
      <h2 class="text-lg font-semibold text-red-800">OAuth Authorization Failed</h2>
    </div>

    <p class="text-red-700 mb-4"><%= @error_message %></p>

    <div class="mt-6">
      <a href="javascript:history.back()" class="inline-flex items-center px-4 py-2 bg-red-600 text-white rounded-md hover:bg-red-700 transition-colors">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Go Back
      </a>
    </div>
  </div>
</div>
