<%# Displays OAuth status for MCP servers that may require authorization %>
<%# Local variables: session, oauth_status %>

<% if oauth_status.present? %>
  <div class="mt-4 p-4 bg-amber-50 border border-amber-200 rounded-lg" data-controller="mcp-oauth-status" data-mcp-oauth-status-session-id-value="<%= session.id %>">
    <h3 class="text-sm font-semibold text-amber-800 mb-3 flex items-center">
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
      </svg>
      OAuth Authorization Required
    </h3>

    <p class="text-sm text-amber-700 mb-4">
      Some MCP servers require OAuth authorization before the session can start.
      Click "Authorize" to grant access for each server.
    </p>

    <div class="space-y-3">
      <% oauth_status.each do |server_name, status| %>
        <div class="flex items-center justify-between p-3 bg-white rounded border border-amber-100">
          <div class="flex items-center">
            <% if status[:has_credentials] && status[:credential_valid] %>
              <span class="flex items-center justify-center w-6 h-6 bg-green-100 rounded-full mr-3">
                <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              </span>
            <% elsif status[:pending_flow] %>
              <span class="flex items-center justify-center w-6 h-6 bg-blue-100 rounded-full mr-3">
                <svg class="w-4 h-4 text-blue-600 animate-spin" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
              </span>
            <% else %>
              <span class="flex items-center justify-center w-6 h-6 bg-amber-100 rounded-full mr-3">
                <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                </svg>
              </span>
            <% end %>

            <div>
              <p class="font-medium text-gray-900"><%= server_name %></p>
              <p class="text-xs text-gray-500"><%= status[:server_url] %></p>
            </div>
          </div>

          <div>
            <% if status[:has_credentials] && status[:credential_valid] %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                Authorized
              </span>
            <% elsif status[:pending_flow] %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                Authorizing...
              </span>
            <% else %>
              <%= form_with url: mcp_oauth_initiate_path, method: :post, local: true, class: "inline" do |f| %>
                <%= f.hidden_field :session_id, value: session.id %>
                <%= f.hidden_field :server_name, value: server_name %>
                <%= f.hidden_field :server_url, value: status[:server_url] %>
                <%= f.submit "Authorize",
                    class: "inline-flex items-center px-3 py-1.5 border border-amber-600 text-sm font-medium rounded-md text-amber-700 bg-white hover:bg-amber-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-amber-500 cursor-pointer" %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <% all_authorized = oauth_status.values.all? { |s| s[:has_credentials] && s[:credential_valid] } %>
    <% if all_authorized %>
      <div class="mt-4 p-3 bg-green-50 border border-green-200 rounded">
        <p class="text-sm text-green-800 flex items-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          All MCP servers are authorized. The session can now start.
        </p>
      </div>
    <% end %>
  </div>
<% end %>
