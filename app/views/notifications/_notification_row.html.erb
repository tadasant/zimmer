<%# A single notification row with session info, timestamp, and mark read/dismiss actions %>
<div class="px-4 sm:px-6 py-4 flex items-center justify-between hover:bg-gray-50 <%= notification.read? ? 'bg-white' : 'bg-blue-50' %> min-w-0 overflow-hidden">
  <div class="flex items-center space-x-3 sm:space-x-4 min-w-0 flex-1">
    <!-- Notification icon with unread indicator -->
    <div class="flex-shrink-0 relative">
      <% if notification.notification_type == 'needs_input' %>
        <div class="h-8 w-8 sm:h-10 sm:w-10 rounded-full bg-yellow-100 flex items-center justify-center">
          <svg class="h-5 w-5 sm:h-6 sm:w-6 text-yellow-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
      <% elsif notification.notification_type == 'session_failed' %>
        <div class="h-8 w-8 sm:h-10 sm:w-10 rounded-full bg-red-100 flex items-center justify-center">
          <svg class="h-5 w-5 sm:h-6 sm:w-6 text-red-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
        </div>
      <% else %>
        <div class="h-8 w-8 sm:h-10 sm:w-10 rounded-full bg-green-100 flex items-center justify-center">
          <svg class="h-5 w-5 sm:h-6 sm:w-6 text-green-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
      <% end %>
      <% unless notification.read? %>
        <span class="absolute -top-1 -right-1 h-3 w-3 bg-blue-500 rounded-full border-2 border-white"></span>
      <% end %>
    </div>

    <!-- Notification content -->
    <div class="min-w-0 flex-1 overflow-hidden">
      <%= link_to click_notification_path(notification), class: "block group" do %>
        <p class="text-sm font-medium text-gray-900 group-hover:text-indigo-600 truncate">
          <%= notification.session.title.presence || "Session #{notification.session.id}" %>
        </p>
        <p class="text-sm text-gray-500 truncate">
          <% case notification.notification_type %>
          <% when 'needs_input' %>
            Needs your input
          <% when 'session_failed' %>
            Session failed
          <% when 'session_complete' %>
            Session completed
          <% else %>
            Status update
          <% end %>
        </p>
      <% end %>
    </div>
  </div>

  <div class="flex items-center space-x-2 sm:space-x-4 flex-shrink-0 ml-2">
    <!-- Timestamp - hidden on very small screens -->
    <span class="hidden sm:inline text-sm text-gray-500 whitespace-nowrap" title="<%= notification.created_at.iso8601 %>">
      <%= time_ago_in_words(notification.created_at) %> ago
    </span>

    <% if notification.read? %>
      <!-- Dismiss button (only show if read) -->
      <%= button_to dismiss_notification_path(notification), method: :delete, class: "text-sm text-gray-400 hover:text-red-600", title: "Dismiss notification" do %>
        <span class="sr-only">Dismiss notification</span>
        <svg class="h-5 w-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      <% end %>
    <% else %>
      <!-- Mark as read button (only show if unread) -->
      <%= button_to mark_read_notification_path(notification), method: :patch, class: "text-sm text-indigo-600 hover:text-indigo-900 whitespace-nowrap" do %>
        Mark read
      <% end %>
    <% end %>
  </div>
</div>
