<%# Floating chat bubble available on every page.
    Opens a slide-out panel for quick routing messages. %>

<%# Limits below are sourced from server-side constants so the JS guards
    track the authoritative values. The chat-bubble file count is intentionally
    capped lower than SessionsController::MAX_FILES_PER_REQUEST (a panel that
    accepts hundreds of files would be unusable). %>
<div data-controller="chat-bubble"
     data-chat-bubble-submit-url-value="<%= chat_bubble_sessions_path %>"
     data-chat-bubble-prompt-max-length-value="<%= Session::PROMPT_MAX_LENGTH %>"
     data-chat-bubble-max-image-size-value="<%= ImageStorageService::MAX_IMAGE_SIZE %>"
     data-chat-bubble-max-images-value="<%= SessionsController::MAX_IMAGES_PER_REQUEST %>"
     data-chat-bubble-max-file-size-value="<%= FileStorageService::MAX_FILE_SIZE %>"
     data-chat-bubble-max-files-value="20"
     data-turbo-permanent
     id="chat-bubble">

  <%# Overlay backdrop.
      Stacking: the Quick Router sits ABOVE the session detail drawer
      (sessions/index.html.erb: backdrop z-[60] / panel z-[65]) so it stays
      reachable while the drawer is open, and BELOW the block-picker banner
      (z-[70]) and the category-edit modal (z-[80]), which must remain on top. %>
  <div data-chat-bubble-target="overlay"
       data-action="click->chat-bubble#close"
       class="hidden fixed inset-0 z-[66] bg-black/20 transition-opacity"></div>

  <%# Slide-out panel %>
  <div data-chat-bubble-target="panel"
       class="fixed bottom-20 right-4 z-[67] w-96 max-w-[calc(100vw-2rem)] translate-x-full opacity-0 pointer-events-none transition-all duration-200 ease-out">
    <div class="bg-white rounded-xl shadow-2xl border border-gray-200 overflow-hidden">
      <%# Header %>
      <div class="flex items-center justify-between px-4 py-3 bg-gray-50 border-b border-gray-200">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
          </svg>
          <h3 class="text-sm font-semibold text-gray-900">Quick Router</h3>
        </div>
        <div class="flex items-center gap-1">
          <span class="text-xs text-gray-400 hidden sm:inline"><kbd class="px-1 py-0.5 bg-gray-200 rounded text-[10px] font-mono">&#8984;/Ctrl+K</kbd></span>
          <button type="button"
                  data-action="chat-bubble#close"
                  class="p-1 text-gray-400 hover:text-gray-600 rounded-md hover:bg-gray-100 transition-colors"
                  aria-label="Close">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>

      <%# Body %>
      <div class="p-4">
        <textarea data-chat-bubble-target="textarea"
                  data-action="keydown->chat-bubble#handleKeydown paste->chat-bubble#handlePaste"
                  placeholder="What do you want to do?"
                  rows="4"
                  class="block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 placeholder-gray-400 shadow-sm resize-y focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"></textarea>

        <%# Attachment preview row - shown when files are attached %>
        <div data-chat-bubble-target="preview" class="hidden mt-2"></div>

        <%# Attach button row %>
        <div class="mt-2 flex items-center gap-2">
          <%# Image attachment button %>
          <button type="button"
                  data-action="chat-bubble#openImageDialog"
                  class="inline-flex items-center p-1.5 border border-gray-300 text-xs font-medium rounded-md text-gray-500 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
                  title="Attach images">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </button>
          <%# Camera button (capture="environment" → rear camera on mobile) %>
          <button type="button"
                  data-action="chat-bubble#openCameraDialog"
                  class="inline-flex items-center p-1.5 border border-gray-300 text-xs font-medium rounded-md text-gray-500 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
                  title="Take photo (mobile camera) or choose image">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </button>
          <%# File attachment button %>
          <button type="button"
                  data-action="chat-bubble#openFileDialog"
                  class="inline-flex items-center p-1.5 border border-gray-300 text-xs font-medium rounded-md text-gray-500 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
                  title="Attach files">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/>
            </svg>
          </button>
          <span class="text-[11px] text-gray-400 ml-auto">Images, photos, files</span>
        </div>

        <%# Hidden file inputs %>
        <input type="file"
               accept="image/jpeg,image/png,image/gif,image/webp"
               multiple
               class="hidden"
               data-chat-bubble-target="imageInput"
               data-action="change->chat-bubble#handleImageSelect">
        <input type="file"
               accept="image/*"
               capture="environment"
               class="hidden"
               data-chat-bubble-target="cameraInput"
               data-action="change->chat-bubble#handleImageSelect">
        <input type="file"
               multiple
               class="hidden"
               data-chat-bubble-target="fileInput"
               data-action="change->chat-bubble#handleFileSelect">

        <p class="mt-1.5 text-xs text-gray-400">
          Page context is automatically included.
          <kbd class="px-1 py-0.5 bg-gray-100 rounded text-[10px] font-mono">&#8984;/Ctrl&#x23CE;</kbd> to submit in background.
        </p>

        <p data-chat-bubble-target="error"
           class="hidden mt-2 text-xs text-red-600 font-medium"></p>
      </div>

      <%# Footer buttons %>
      <div class="flex items-center gap-2 px-4 py-3 bg-gray-50 border-t border-gray-200">
        <button type="button"
                data-chat-bubble-target="submitButton"
                data-action="chat-bubble#submitBackground"
                class="flex-1 inline-flex justify-center items-center px-3 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
          Submit
        </button>
        <button type="button"
                data-chat-bubble-target="submitOpenButton"
                data-action="chat-bubble#submitAndOpen"
                class="inline-flex justify-center items-center px-3 py-2 text-sm font-medium text-indigo-600 bg-white border border-indigo-300 rounded-lg shadow-sm hover:bg-indigo-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
          Submit & Open
        </button>
      </div>
    </div>
  </div>

  <%# Floating action button %>
  <button type="button"
          data-action="chat-bubble#toggle"
          class="fixed bottom-4 right-4 z-[67] flex items-center justify-center w-12 h-12 bg-indigo-600 text-white rounded-full shadow-lg hover:bg-indigo-500 hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all duration-200 group"
          aria-label="Open quick router">
    <%# Chat icon %>
    <svg class="w-6 h-6 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
    </svg>

    <%# Success badge (briefly shown after background submit) %>
    <span data-chat-bubble-target="badge"
          class="hidden absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-green-500 text-white">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
      </svg>
    </span>
  </button>
</div>
