<%# MCP server log entry - displays connection status and debug/error messages %>
<div class="px-6 py-4 regular-log">
  <div class="flex items-start space-x-3">
    <div class="flex-shrink-0">
      <div class="h-8 w-8 rounded-full <%= item[:level] == 'error' ? 'bg-red-100' : 'bg-purple-100' %> flex items-center justify-center">
        <% if item[:level] == 'error' %>
          <svg class="h-5 w-5 text-red-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        <% else %>
          <%# MCP/Plugin icon for non-error logs %>
          <svg class="h-5 w-5 text-purple-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
          </svg>
        <% end %>
      </div>
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center justify-between">
        <p class="text-sm font-medium text-gray-900">
          <span class="text-purple-600">MCP</span>
          <% if item[:server_name].present? %>
            <span class="text-gray-500">:</span>
            <span class="text-gray-700"><%= item[:server_name] %></span>
          <% end %>
        </p>
        <% if item[:timestamp].present? %>
          <p class="text-xs text-gray-500" data-timestamp="<%= item[:timestamp].iso8601 %>" data-controller="timestamp-updater"><%= time_ago_in_words(item[:timestamp]) %> ago</p>
        <% end %>
      </div>
      <div class="mt-2 <%= item[:level] == 'error' ? 'mcp-log-error' : 'mcp-log' %>">
        <%= render "shared/enhanced_markdown", content: item[:content] %>
      </div>
    </div>
  </div>
</div>
