<%#
  Unified timeline item renderer.

  Every normalized transcript event is an OpenTranscripts event (see
  OpenTranscript / docs/OPEN_TRANSCRIPTS.md) and is rendered through this single
  partial, keyed on item[:type]. Logs and MCP logs are not OpenTranscripts
  events and keep their dedicated partials.

  Local variables:
    item:    Hash - a timeline item (OpenTranscripts event, or a log/mcp_log)
    session: Session - optional, enables fork affordance and subagent accordions
    nested:  Boolean - optional, true when rendered inside a subagent accordion.
             Nested items omit data-timeline-item / data-filter-category so the
             parent timeline's infinite-scroll counter and log-level filter
             (which query those attributes) never reach into accordion contents.
%>
<% nested = local_assigns.fetch(:nested, false) %>
<% if OpenTranscript.blank_message?(item) %>
  <%# Content-less message event (e.g. a Claude assistant line carrying only
      tool_use/thinking blocks). The event is retained in the normalized stream
      for usage metrics and child parent-linkage, but renders no row — the
      universal suppression point shared by every timeline render path. %>
<% else %>
<div<% unless nested %> data-timeline-item data-filter-category="<%= OpenTranscript.filter_category(item) %>"<% end %>>
<% if item[:type] == "mcp_log" %>
  <%= render "timeline_items/mcp_log", item: item %>
<% elsif item[:type] == "log" %>
  <%= render "timeline_items/log", item: item %>
<% else %>
  <%
    session = local_assigns[:session]
    body = ot_content_markdown(item)
    label = ot_event_label(item)
    icon_kind = ot_icon_kind(item)
    is_message = [ OpenTranscript::Types::USER_MESSAGE, OpenTranscript::Types::ASSISTANT_MESSAGE ].include?(item[:type])
    forkable = is_message && session && item[:transcript_index].present?
    image_count = is_message ? ot_image_count(item) : 0
  %>
  <div class="px-6 py-4 <%= 'bg-gray-50' if ot_tool_row?(item) %> group/message"
       data-controller="message-copy<%= ' fork-session' if forkable %>"
       data-message-copy-content-value="<%= body.to_json %>"
       <% if forkable %>
       data-fork-session-url-value="<%= fork_session_path(session) %>"
       data-fork-session-message-index-value="<%= item[:transcript_index] %>"
       <% end %>>
    <div class="flex items-start space-x-3">
      <div class="flex-shrink-0">
        <div class="h-8 w-8 rounded-full <%= ot_badge_class(item) %> flex items-center justify-center">
          <% case icon_kind %>
          <% when :user %>
            <svg class="h-5 w-5 <%= ot_icon_color(item) %>" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" />
            </svg>
          <% when :assistant %>
            <svg class="h-5 w-5 <%= ot_icon_color(item) %>" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path d="M2 5a2 2 0 012-2h7a2 2 0 012 2v4a2 2 0 01-2 2H9l-3 3v-3H4a2 2 0 01-2-2V5z" />
              <path d="M15 7v2a4 4 0 01-4 4H9.828l-1.766 1.767c.28.149.599.233.938.233h2l3 3v-3h2a2 2 0 002-2V9a2 2 0 00-2-2h-1z" />
            </svg>
          <% when :tool %>
            <svg class="h-5 w-5 <%= ot_icon_color(item) %>" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
            </svg>
          <% when :thinking %>
            <svg class="h-5 w-5 <%= ot_icon_color(item) %>" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" />
              <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd" />
            </svg>
          <% when :error %>
            <svg class="h-5 w-5 <%= ot_icon_color(item) %>" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
          <% else %>
            <svg class="h-5 w-5 <%= ot_icon_color(item) %>" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
            </svg>
          <% end %>
        </div>
      </div>
      <div class="flex-1 min-w-0">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <p class="text-sm font-medium text-gray-900"><%= label %></p>
            <% if image_count > 0 %>
              <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-700" title="<%= pluralize(image_count, 'image') %> attached">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <%= image_count %>
              </span>
            <% end %>
          </div>
          <div class="flex items-center space-x-2">
            <% if forkable %>
              <button type="button"
                      data-fork-session-target="button"
                      data-action="click->fork-session#fork"
                      title="Fork conversation from this point"
                      aria-label="Fork conversation from this point"
                      class="p-1 rounded bg-gray-100 text-gray-500 hover:bg-gray-200 hover:text-gray-700 opacity-0 group-hover/message:opacity-100 focus:opacity-100 transition-opacity duration-150">
                <svg data-fork-session-target="forkIcon" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                </svg>
                <svg data-fork-session-target="spinnerIcon" class="h-4 w-4 hidden animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <svg data-fork-session-target="checkIcon" class="h-4 w-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <svg data-fork-session-target="errorIcon" class="h-4 w-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            <% end %>
            <button type="button"
                    data-message-copy-target="button"
                    data-action="click->message-copy#copy"
                    title="Copy message content"
                    aria-label="Copy message content to clipboard"
                    class="p-1 rounded bg-gray-100 text-gray-500 hover:bg-gray-200 hover:text-gray-700 opacity-0 group-hover/message:opacity-100 focus:opacity-100 transition-opacity duration-150">
              <svg data-message-copy-target="copyIcon" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
              <svg data-message-copy-target="checkIcon" class="h-4 w-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <svg data-message-copy-target="errorIcon" class="h-4 w-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
            <% if item[:sort_time].present? %>
              <p class="text-xs text-gray-500" data-timestamp="<%= item[:sort_time].iso8601 %>" data-controller="timestamp-updater"><%= time_ago_in_words(item[:sort_time]) %> ago</p>
            <% end %>
          </div>
        </div>
        <div class="mt-2">
          <%= render "shared/enhanced_markdown", content: body %>
        </div>
      </div>
    </div>
  </div>

  <%# Subagent accordion: a SubagentSpawn links to a stored subagent transcript by tool_call_id. %>
  <% if item[:type] == OpenTranscript::Types::SUBAGENT_SPAWN && session && item[:tool_call_id].present? %>
    <% subagent = session.subagent_transcripts.find_by(tool_use_id: item[:tool_call_id]) %>
    <% if subagent %>
      <div class="px-6 pb-4">
        <%= render "subagent_transcripts/accordion", subagent: subagent, session: session %>
      </div>
    <% end %>
  <% end %>
<% end %>
</div>
<% end %>
