<%# Subagent transcript accordion %>
<%# Displays nested agent transcript inline with expandable content %>
<%#
  Local variables:
    subagent: SubagentTranscript - the subagent record
    session: Session - parent session (optional, defaults to subagent.session)
%>
<% session ||= subagent.session %>

<div class="mt-2 mb-2 border border-gray-200 rounded-lg overflow-hidden bg-white shadow-sm"
     data-controller="subagent-accordion"
     data-subagent-accordion-agent-id-value="<%= subagent.agent_id %>"
     data-subagent-accordion-expanded-value="false"
     id="subagent_accordion_<%= subagent.agent_id %>">

  <%# Accordion Header %>
  <button type="button"
          class="w-full px-4 py-3 flex items-center justify-between text-left bg-gray-50 hover:bg-gray-100 transition-colors"
          data-action="click->subagent-accordion#toggle">
    <div class="flex items-center space-x-3">
      <%# Chevron %>
      <svg class="h-4 w-4 text-gray-500 transform transition-transform duration-200"
           data-subagent-accordion-target="chevron"
           xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
      </svg>

      <%# Status Icon %>
      <% if subagent.running? %>
        <%# Running spinner %>
        <div class="flex-shrink-0">
          <svg class="animate-spin h-5 w-5 text-blue-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </div>
      <% elsif subagent.completed? %>
        <%# Completed checkmark %>
        <div class="flex-shrink-0 h-5 w-5 rounded-full bg-green-100 flex items-center justify-center">
          <svg class="h-3.5 w-3.5 text-green-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
        </div>
      <% elsif subagent.failed? %>
        <%# Failed X %>
        <div class="flex-shrink-0 h-5 w-5 rounded-full bg-red-100 flex items-center justify-center">
          <svg class="h-3.5 w-3.5 text-red-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </div>
      <% else %>
        <%# Unknown/default icon %>
        <div class="flex-shrink-0 h-5 w-5 rounded-full bg-gray-100 flex items-center justify-center">
          <svg class="h-3.5 w-3.5 text-gray-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
          </svg>
        </div>
      <% end %>

      <%# Label and Type %>
      <div class="flex flex-col">
        <span class="text-sm font-medium text-gray-900">
          Subagent: <%= subagent.display_label %>
        </span>
        <% if subagent.subagent_type.present? %>
          <span class="text-xs text-gray-500">
            Type: <%= subagent.subagent_type %>
          </span>
        <% end %>
      </div>
    </div>

    <%# Stats badges %>
    <div class="flex items-center space-x-2 text-xs text-gray-500">
      <% if subagent.running? %>
        <span class="px-2 py-0.5 rounded-full bg-blue-100 text-blue-700">
          Running...
        </span>
      <% else %>
        <% if subagent.status.present? && !subagent.running? %>
          <span class="px-2 py-0.5 rounded-full <%= subagent.completed? ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
            <%= subagent.status.capitalize %>
          </span>
        <% end %>
      <% end %>

      <% if subagent.message_count.present? && subagent.message_count > 0 %>
        <span class="px-2 py-0.5 rounded-full bg-gray-100 text-gray-600">
          <%= subagent.message_count %> messages
        </span>
      <% end %>

      <% if subagent.tool_use_count.present? && subagent.tool_use_count > 0 %>
        <span class="px-2 py-0.5 rounded-full bg-purple-100 text-purple-700">
          <%= subagent.tool_use_count %> tool calls
        </span>
      <% end %>

      <% if subagent.formatted_tokens.present? %>
        <span class="px-2 py-0.5 rounded-full bg-gray-100 text-gray-600">
          <%= subagent.formatted_tokens %> tokens
        </span>
      <% end %>

      <% if subagent.formatted_duration.present? %>
        <span class="px-2 py-0.5 rounded-full bg-gray-100 text-gray-600">
          <%= subagent.formatted_duration %>
        </span>
      <% end %>
    </div>
  </button>

  <%# Accordion Content — same turbo frame the poller replaces on live updates %>
  <div class="hidden border-t border-gray-200"
       data-subagent-accordion-target="content">
    <%= render "subagent_transcripts/messages", subagent: subagent, session: session %>
  </div>
</div>
