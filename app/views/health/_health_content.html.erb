<div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
  <!-- Process Health Section -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-medium text-gray-900">Process Health</h3>
        <%= status_badge(health_report[:process_health][:status]) %>
      </div>
    </div>
    <div class="px-4 py-5 sm:p-6">
      <dl class="grid grid-cols-3 gap-4 mb-6">
        <div class="text-center">
          <dt class="text-sm font-medium text-gray-500">Active</dt>
          <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= health_report[:process_health][:active_count] %></dd>
        </div>
        <div class="text-center">
          <dt class="text-sm font-medium text-gray-500">Tracked</dt>
          <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= health_report[:process_health][:tracked_count] %></dd>
        </div>
        <div class="text-center">
          <dt class="text-sm font-medium text-gray-500">Orphaned</dt>
          <dd class="mt-1 text-2xl font-semibold <%= health_report[:process_health][:orphaned_count] > 0 ? 'text-red-600' : 'text-gray-900' %>">
            <%= health_report[:process_health][:orphaned_count] %>
          </dd>
        </div>
      </dl>

      <% if health_report[:process_health][:orphaned_processes].any? %>
        <div class="mb-4">
          <h4 class="text-sm font-medium text-gray-700 mb-2">Orphaned Processes</h4>
          <div class="bg-red-50 rounded-md p-3">
            <ul class="text-sm text-red-700 space-y-1">
              <% health_report[:process_health][:orphaned_processes].each do |process| %>
                <li class="flex justify-between">
                  <span class="font-mono">PID <%= process[:pid] %></span>
                  <span class="text-red-600 truncate ml-2 max-w-xs"><%= process[:command].truncate(50) %></span>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      <% end %>

      <% if health_report[:process_health][:orphaned_count] > 0 %>
        <%= button_to "Clean Up Orphaned Processes", cleanup_processes_health_path,
            method: :post,
            data: { confirm: "Are you sure you want to terminate #{health_report[:process_health][:orphaned_count]} orphaned process(es)?" },
            class: "w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
      <% end %>
    </div>
  </div>

  <!-- Session Health Section -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-medium text-gray-900">Session Health</h3>
        <%= status_badge(health_report[:session_health][:status]) %>
      </div>
    </div>
    <div class="px-4 py-5 sm:p-6">
      <dl class="grid grid-cols-2 gap-4 mb-6">
        <div class="text-center">
          <dt class="text-sm font-medium text-gray-500">Total Sessions</dt>
          <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= health_report[:session_health][:total_sessions] %></dd>
        </div>
        <div class="text-center">
          <dt class="text-sm font-medium text-gray-500">Failure Rate</dt>
          <dd class="mt-1 text-2xl font-semibold <%= health_report[:session_health][:failure_rate] > 0.1 ? 'text-red-600' : 'text-gray-900' %>">
            <%= (health_report[:session_health][:failure_rate] * 100).round(1) %>%
          </dd>
        </div>
      </dl>

      <!-- Status Distribution -->
      <div class="mb-4">
        <h4 class="text-sm font-medium text-gray-700 mb-2">Status Distribution</h4>
        <div class="flex flex-wrap gap-2">
          <% health_report[:session_health][:sessions_by_status].each do |status, count| %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= session_status_color(status) %>">
              <%= status %>: <%= count %>
            </span>
          <% end %>
        </div>
      </div>

      <% if health_report[:session_health][:error_categories].any? %>
        <div class="mb-4">
          <h4 class="text-sm font-medium text-gray-700 mb-2">Error Categories (24h)</h4>
          <div class="flex flex-wrap gap-2">
            <% health_report[:session_health][:error_categories].each do |category, count| %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                <%= category %>: <%= count %>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if health_report[:session_health][:failure_reasons].any? %>
        <div class="mb-4">
          <h4 class="text-sm font-medium text-gray-700 mb-2">Failure Reasons (24h)</h4>
          <div class="flex flex-wrap gap-2">
            <% health_report[:session_health][:failure_reasons].each do |reason, count| %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= reason == 'unknown' ? 'bg-gray-100 text-gray-800' : 'bg-orange-100 text-orange-800' %>">
                <%= reason.humanize %>: <%= count %>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if health_report[:session_health][:recent_failures].any? %>
        <%= button_to "Retry Failed Sessions", retry_sessions_health_path,
            method: :post,
            data: { confirm: "Are you sure you want to retry #{health_report[:session_health][:recent_failures].size} failed session(s)?" },
            class: "w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-yellow-600 hover:bg-yellow-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-yellow-500" %>
      <% end %>
    </div>
  </div>

  <!-- System Health Section -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-medium text-gray-900">System Health</h3>
        <%= status_badge(health_report[:system_health][:status]) %>
      </div>
    </div>
    <div class="px-4 py-5 sm:p-6">
      <dl class="grid grid-cols-2 gap-4 mb-6">
        <div class="text-center">
          <dt class="text-sm font-medium text-gray-500">Queue Depth</dt>
          <dd class="mt-1 text-2xl font-semibold <%= health_report[:system_health][:queue_depth] > 50 ? 'text-yellow-600' : 'text-gray-900' %>">
            <%= health_report[:system_health][:queue_depth] %>
          </dd>
        </div>
        <div class="text-center">
          <dt class="text-sm font-medium text-gray-500">Jobs/Hour</dt>
          <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= health_report[:system_health][:queue_stats][:processing_rate_per_hour] %></dd>
        </div>
      </dl>

      <!-- Queue Stats -->
      <div class="mb-4">
        <h4 class="text-sm font-medium text-gray-700 mb-2">Queue Statistics</h4>
        <div class="grid grid-cols-4 gap-2 text-center text-sm">
          <div class="bg-gray-50 rounded p-2">
            <div class="font-medium text-gray-900"><%= health_report[:system_health][:queue_stats][:ready_count] %></div>
            <div class="text-gray-500 text-xs">Ready</div>
          </div>
          <div class="bg-gray-50 rounded p-2">
            <div class="font-medium text-gray-900"><%= health_report[:system_health][:queue_stats][:scheduled_count] %></div>
            <div class="text-gray-500 text-xs">Scheduled</div>
          </div>
          <div class="bg-gray-50 rounded p-2">
            <div class="font-medium text-gray-900"><%= health_report[:system_health][:queue_stats][:claimed_count] %></div>
            <div class="text-gray-500 text-xs">Processing</div>
          </div>
          <div class="bg-gray-50 rounded p-2">
            <div class="font-medium <%= health_report[:system_health][:queue_stats][:failed_count] > 0 ? 'text-red-600' : 'text-gray-900' %>"><%= health_report[:system_health][:queue_stats][:failed_count] %></div>
            <div class="text-gray-500 text-xs">Failed</div>
          </div>
        </div>
      </div>

      <!-- Worker Stats -->
      <div class="mb-4">
        <h4 class="text-sm font-medium text-gray-700 mb-2">Workers</h4>
        <div class="text-sm text-gray-600">
          <span class="font-medium"><%= health_report[:system_health][:worker_stats][:active_workers] %></span> active /
          <span class="font-medium"><%= health_report[:system_health][:worker_stats][:total_workers] %></span> total workers,
          <span class="font-medium"><%= health_report[:system_health][:worker_stats][:dispatchers] %></span> dispatchers
        </div>
      </div>

      <!-- Database Status -->
      <div>
        <h4 class="text-sm font-medium text-gray-700 mb-2">Database</h4>
        <% if health_report[:system_health][:database_status][:connected] %>
          <div class="text-sm text-green-600">
            Connected (Pool: <%= health_report[:system_health][:database_status][:connections_in_use] %>/<%= health_report[:system_health][:database_status][:pool_size] %> in use)
          </div>
        <% else %>
          <div class="text-sm text-red-600">
            Disconnected: <%= health_report[:system_health][:database_status][:error] %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- SIGTERM Retry Health Section -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-medium text-gray-900">SIGTERM Auto-Retry</h3>
        <% if health_report[:sigterm_retry_health][:rate_limit_pressure] %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
            Under Pressure
          </span>
        <% else %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
            Normal
          </span>
        <% end %>
      </div>
    </div>
    <div class="px-4 py-5 sm:p-6">
      <dl class="grid grid-cols-2 gap-4 mb-6">
        <div class="text-center">
          <dt class="text-sm font-medium text-gray-500">Recovered</dt>
          <dd class="mt-1 text-2xl font-semibold text-green-600"><%= health_report[:sigterm_retry_health][:successful_recovery_count] %></dd>
        </div>
        <div class="text-center">
          <dt class="text-sm font-medium text-gray-500">Exhausted</dt>
          <dd class="mt-1 text-2xl font-semibold <%= health_report[:sigterm_retry_health][:exhausted_retry_count] > 0 ? 'text-red-600' : 'text-gray-900' %>">
            <%= health_report[:sigterm_retry_health][:exhausted_retry_count] %>
          </dd>
        </div>
      </dl>

      <!-- Retry Statistics -->
      <div class="mb-4">
        <h4 class="text-sm font-medium text-gray-700 mb-2">Retry Statistics</h4>
        <div class="grid grid-cols-3 gap-2 text-center text-sm">
          <div class="bg-gray-50 rounded p-2">
            <div class="font-medium text-gray-900"><%= health_report[:sigterm_retry_health][:total_sigterm_sessions] %></div>
            <div class="text-gray-500 text-xs">Total Sessions</div>
          </div>
          <div class="bg-gray-50 rounded p-2">
            <div class="font-medium text-gray-900"><%= health_report[:sigterm_retry_health][:total_retries_attempted] %></div>
            <div class="text-gray-500 text-xs">Total Retries</div>
          </div>
          <div class="bg-gray-50 rounded p-2">
            <div class="font-medium <%= health_report[:sigterm_retry_health][:recent_sigterm_count] > 0 ? 'text-yellow-600' : 'text-gray-900' %>"><%= health_report[:sigterm_retry_health][:recent_sigterm_count] %></div>
            <div class="text-gray-500 text-xs">Last 24h</div>
          </div>
        </div>
      </div>

      <!-- Rate Limit Status -->
      <div class="mb-4">
        <h4 class="text-sm font-medium text-gray-700 mb-2">Rate Limit Status</h4>
        <div class="text-sm text-gray-600">
          <span class="font-medium"><%= health_report[:sigterm_retry_health][:rate_limit_events_5min] %></span> events in last 5 min
          <span class="mx-2">·</span>
          Delay mode: <span class="font-medium <%= health_report[:sigterm_retry_health][:current_delay_mode] == 'escalated' ? 'text-yellow-600' : 'text-gray-900' %>"><%= health_report[:sigterm_retry_health][:current_delay_mode] %></span>
          <span class="mx-2">·</span>
          Max retries: <span class="font-medium"><%= health_report[:sigterm_retry_health][:max_retries] %></span>
        </div>
      </div>

      <% if health_report[:sigterm_retry_health][:current_delay_mode] == "escalated" %>
        <div class="rounded-md bg-yellow-50 p-3">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-yellow-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <p class="text-sm text-yellow-700">
                System is experiencing rate limit pressure. Retry delays are escalated (60s, 180s, 300s) to allow recovery.
              </p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- API Error Auto-Retry Health Section -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-medium text-gray-900">API Error Auto-Retry</h3>
        <div class="flex gap-2">
          <% if health_report[:api_error_retry_health][:recent_quota_limit_count] > 0 %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
              Quota Limit Hit
            </span>
          <% end %>
          <% if health_report[:api_error_retry_health][:rate_limit_pressure] %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
              Under Pressure
            </span>
          <% elsif health_report[:api_error_retry_health][:recent_quota_limit_count] == 0 %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
              Normal
            </span>
          <% end %>
        </div>
      </div>
      <p class="mt-1 text-sm text-gray-500">Handles API server errors (500, 529) and transient rate limits (429) with adaptive backoff. Account quota limits are detected and skipped.</p>
    </div>
    <div class="px-4 py-5 sm:p-6">
      <dl class="grid grid-cols-3 gap-4 mb-6">
        <div class="text-center">
          <dt class="text-sm font-medium text-gray-500">Recovered</dt>
          <dd class="mt-1 text-2xl font-semibold text-green-600"><%= health_report[:api_error_retry_health][:successful_recovery_count] %></dd>
        </div>
        <div class="text-center">
          <dt class="text-sm font-medium text-gray-500">Exhausted</dt>
          <dd class="mt-1 text-2xl font-semibold <%= health_report[:api_error_retry_health][:exhausted_retry_count] > 0 ? 'text-red-600' : 'text-gray-900' %>">
            <%= health_report[:api_error_retry_health][:exhausted_retry_count] %>
          </dd>
        </div>
        <div class="text-center">
          <dt class="text-sm font-medium text-gray-500">Quota Limits</dt>
          <dd class="mt-1 text-2xl font-semibold <%= health_report[:api_error_retry_health][:quota_limit_sessions_count] > 0 ? 'text-orange-600' : 'text-gray-900' %>">
            <%= health_report[:api_error_retry_health][:quota_limit_sessions_count] %>
          </dd>
        </div>
      </dl>

      <!-- Retry Statistics -->
      <div class="mb-4">
        <h4 class="text-sm font-medium text-gray-700 mb-2">Retry Statistics</h4>
        <div class="grid grid-cols-4 gap-2 text-center text-sm">
          <div class="bg-gray-50 rounded p-2">
            <div class="font-medium text-gray-900"><%= health_report[:api_error_retry_health][:total_api_error_sessions] %></div>
            <div class="text-gray-500 text-xs">Total Sessions</div>
          </div>
          <div class="bg-gray-50 rounded p-2">
            <div class="font-medium text-gray-900"><%= health_report[:api_error_retry_health][:total_retries_attempted] %></div>
            <div class="text-gray-500 text-xs">Total Retries</div>
          </div>
          <div class="bg-gray-50 rounded p-2">
            <div class="font-medium <%= health_report[:api_error_retry_health][:recent_api_error_count] > 0 ? 'text-yellow-600' : 'text-gray-900' %>"><%= health_report[:api_error_retry_health][:recent_api_error_count] %></div>
            <div class="text-gray-500 text-xs">Errors 24h</div>
          </div>
          <div class="bg-gray-50 rounded p-2">
            <div class="font-medium <%= health_report[:api_error_retry_health][:recent_quota_limit_count] > 0 ? 'text-orange-600' : 'text-gray-900' %>"><%= health_report[:api_error_retry_health][:recent_quota_limit_count] %></div>
            <div class="text-gray-500 text-xs">Quota Limits 24h</div>
          </div>
        </div>
      </div>

      <% if health_report[:api_error_retry_health][:recent_quota_limit_count] > 0 %>
        <div class="rounded-md bg-orange-50 p-3 mb-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-orange-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <p class="text-sm text-orange-700">
                <%= health_report[:api_error_retry_health][:recent_quota_limit_count] %> session(s) hit an account quota limit in the last 24 hours. These are daily/weekly limits that require hours to reset — retry was correctly skipped.
              </p>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Rate Limit Status -->
      <div class="mb-4">
        <h4 class="text-sm font-medium text-gray-700 mb-2">Rate Limit Status</h4>
        <div class="text-sm text-gray-600">
          <span class="font-medium"><%= health_report[:api_error_retry_health][:rate_limit_events_5min] %></span> events in last 5 min
          <span class="mx-2">·</span>
          Delay mode: <span class="font-medium <%= health_report[:api_error_retry_health][:current_delay_mode] == 'escalated' ? 'text-yellow-600' : 'text-gray-900' %>"><%= health_report[:api_error_retry_health][:current_delay_mode] %></span>
          <span class="mx-2">·</span>
          Max retries: <span class="font-medium"><%= health_report[:api_error_retry_health][:max_retries] %></span>
        </div>
      </div>

      <% if health_report[:api_error_retry_health][:current_delay_mode] == "escalated" %>
        <div class="rounded-md bg-yellow-50 p-3">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-yellow-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <p class="text-sm text-yellow-700">
                System is experiencing rate limit pressure. API error retry delays are escalated (60s, 180s, 300s) to allow recovery.
              </p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Actions Section -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900">Maintenance Actions</h3>
    </div>
    <div class="px-4 py-5 sm:p-6 space-y-4">
      <%= button_to "Trash Sessions Older Than 7 Days", archive_old_health_path(days: 7),
          method: :post,
          data: { confirm: "Are you sure you want to move all sessions older than 7 days to trash?" },
          class: "w-full inline-flex justify-center items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>

      <%= link_to good_job_path, class: "w-full inline-flex justify-center items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
        <svg class="-ml-1 mr-2 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
        </svg>
        Open Job Queue Dashboard
      <% end %>

      <%= link_to supervisor_root_path, class: "w-full inline-flex justify-center items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
        <svg class="-ml-1 mr-2 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
          <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
        </svg>
        Open Supervisor Dashboard
      <% end %>
    </div>
  </div>
</div>

<!-- Recent Failures Section (Full Width) -->
<% if health_report[:session_health][:recent_failures].any? %>
  <div class="mt-6 bg-white rounded-lg shadow">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900">Recent Failures (24h)</h3>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Session</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Agent Root</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Failure Reason</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Last Error</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Updated</th>
            <th scope="col" class="relative px-6 py-3"><span class="sr-only">Actions</span></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% health_report[:session_health][:recent_failures].each do |failure| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900">
                  <%= link_to failure[:title] || "Session ##{failure[:id]}", session_path(failure[:slug] || failure[:id]), class: "text-indigo-600 hover:text-indigo-900" %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= failure[:git_root]&.split("/")&.last || "N/A" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <% if failure[:failure_reason].present? %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-orange-100 text-orange-800">
                    <%= failure[:failure_reason].humanize %>
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                    Unknown
                  </span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500 max-w-xs truncate">
                <%= failure[:last_error] || "No error logged" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= time_ago_in_words(failure[:updated_at]) %> ago
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <%= link_to "View", session_path(failure[:slug] || failure[:id]), class: "text-indigo-600 hover:text-indigo-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>

<!-- Recent Errors Section (Full Width) -->
<% if health_report[:system_health][:recent_errors].any? %>
  <div class="mt-6 bg-white rounded-lg shadow">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900">Recent Error Logs (1h)</h3>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Time</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Session</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Error</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% health_report[:system_health][:recent_errors].each do |error_log| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= error_log[:created_at].strftime("%H:%M:%S") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <% if error_log[:session_id] %>
                  <%= link_to "##{error_log[:session_id]}", session_path(error_log[:session_id]), class: "text-indigo-600 hover:text-indigo-900" %>
                <% else %>
                  N/A
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm text-red-600 max-w-lg truncate">
                <%= error_log[:content] %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>

<!-- Recent SIGTERM Sessions (Full Width) -->
