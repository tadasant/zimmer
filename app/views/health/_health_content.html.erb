                  <%= sigterm_session[:status] %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <% if sigterm_session[:last_sigterm_at] %>
                  <%= time_ago_in_words(sigterm_session[:last_sigterm_at]) %> ago
                <% else %>
                  N/A
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <%= link_to "View", session_path(sigterm_session[:slug] || sigterm_session[:id]), class: "text-indigo-600 hover:text-indigo-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
