<style>
  .sortable-ghost {
    opacity: 0.4;
    border: 2px dashed #818cf8;
    border-radius: 0.5rem;
    background: #eef2ff;
    box-shadow: none;
  }
  .sortable-ghost > * { opacity: 0; }
  .sortable-chosen {
    box-shadow: 0 0 0 2px #818cf8;
    border-radius: 0.5rem;
    transform: scale(1.02);
    z-index: 30;
  }
  .sortable-drag {
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    transform: rotate(1.5deg) scale(1.03);
    border-radius: 0.5rem;
    opacity: 0.95;
  }
  /* An empty category grid still needs to read as a drop target. Show a dashed
     "Drop sessions here" hint only while it has no cards. */
  .category-grid:not(:has(*))::after {
    content: "Drop sessions here";
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 5rem;
    color: #9ca3af;
    font-size: 0.875rem;
    border: 2px dashed #e5e7eb;
    border-radius: 0.5rem;
  }
  /* Collapsible category sections. The category-collapse controller toggles
     `category-collapsed` on the <section> and persists it to localStorage; the chevron
     (in the header) lives outside the section's turbo-frame so it survives pagination
     swaps. Hiding the frame collapses the grid and its pagination together. */
  .category-collapse-chevron {
    transition: transform 0.2s ease;
  }
  .category-collapsed .category-collapse-chevron {
    transform: rotate(-90deg);
  }
  .category-collapsed .category-collapse-body {
    display: none;
  }
  /* "Click to pick a blocker" mode: every session card becomes a click target. */
  .block-picking [data-block-picker-card-id] {
    cursor: pointer;
  }
  .block-picking [data-block-picker-card-id]:hover {
    outline: 2px solid #f59e0b;
    outline-offset: 2px;
    border-radius: 0.5rem;
  }
</style>
<div class="min-h-screen bg-gray-50"
     data-controller="pull-to-refresh dashboard-notes stream-visibility-recovery block-picker session-drawer"
     data-block-picker-mark-url-template-value="<%= mark_blocked_session_path("__ID__") %>">
  <%# Blocker-selection banner: shown while picking a session to block by. %>
  <div data-block-picker-target="banner" class="hidden sticky top-0 z-[70] bg-amber-500 text-white px-4 py-2 shadow-md">
    <div class="flex items-center justify-between gap-3">
      <div class="flex items-center gap-2 text-sm font-medium">
        <svg class="h-4 w-4 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
        </svg>
        <span data-block-picker-target="label">Select the session that is blocking this one — click any session card.</span>
      </div>
      <button type="button" data-action="click->block-picker#cancel" class="inline-flex items-center px-2.5 py-1 text-xs font-medium rounded-md bg-white/20 hover:bg-white/30 flex-shrink-0">
        Cancel (Esc)
      </button>
    </div>
  </div>
