<span id="session_<%= agent_session.id %>_status_badge"
      class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-medium <%= status_badge_classes(agent_session) %>"
      <%= 'data-running-badge' if agent_session.status == 'running' %>>
  <% if agent_session.status == 'running' %>
    <div class="relative inline-flex items-center">
      <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      <% if agent_session.last_timeline_entry_at.present? %>
        <span class="absolute inset-0 flex items-center justify-center text-[8px] font-bold"
              data-controller="time-since"
              data-time-since-update-badge-color-value="true"
              data-timestamp="<%= agent_session.last_timeline_entry_at.iso8601 %>">
        </span>
      <% end %>
    </div>
  <% end %>
  <%= agent_session.archived? ? "Trashed" : agent_session.status.titleize %>
</span>
