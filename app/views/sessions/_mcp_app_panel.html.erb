<%# MCP Apps spike panel (SEP-1865 / io.modelcontextprotocol/ui).
    Rendered only when McpAppPreviewService is enabled and a preview was fetched.
    `preview` is the parsed Node-bridge payload: serverInfo, tool, input,
    toolResult, and the ui:// fragment (html + csp). Zimmer connected to the
    MCP server as its own host, called the tool, and read the fragment; the
    mcp-app-host Stimulus controller renders it in a sandboxed iframe and speaks
    the MCP-Apps postMessage protocol to it. %>
<% ui = preview["ui"] || {} %>
<div class="bg-white shadow rounded-lg mb-4 overflow-hidden border border-indigo-100"
     data-controller="mcp-app-host"
     data-mcp-app-host-html-value="<%= ui["html"] %>"
     data-mcp-app-host-tool-result-value="<%= (preview["toolResult"] || {}).to_json %>"
     data-mcp-app-host-tool-value="<%= (preview["tool"] || {}).to_json %>"
     data-mcp-app-host-input-value="<%= (preview["input"] || {}).to_json %>"
     data-mcp-app-host-server-url-value="<%= preview["serverUrl"] %>"
     data-mcp-app-host-session-id-value="<%= (defined?(session) && session) ? session.id : "" %>"
     data-mcp-app-host-theme-value="light">
  <div class="px-4 py-3 border-b border-gray-100 bg-indigo-50/60 flex items-center justify-between gap-2">
    <div class="flex items-center gap-2 min-w-0">
      <span class="inline-flex items-center rounded-full bg-indigo-600/10 px-2 py-0.5 text-xs font-semibold text-indigo-700">MCP App</span>
      <span class="text-sm font-medium text-gray-900 truncate">
        <%= preview.dig("serverInfo", "name") || "MCP server" %> · <code class="text-indigo-700"><%= preview.dig("tool", "name") %></code>
      </span>
    </div>
    <span class="text-[11px] text-gray-500 shrink-0" data-mcp-app-host-target="status">loading…</span>
  </div>

  <div class="px-4 py-2 text-[11px] text-gray-500 border-b border-gray-100">
    Fragment <code><%= ui["uri"] %></code> (<code><%= ui["mimeType"] %></code>) fetched by Zimmer acting as its own MCP host, then rendered in a sandboxed iframe below.
  </div>

  <div class="p-4 flex justify-center">
    <iframe data-mcp-app-host-target="frame"
            title="MCP App fragment"
            class="w-[400px] h-[360px] border-0 bg-transparent"
            referrerpolicy="no-referrer"></iframe>
  </div>
</div>
