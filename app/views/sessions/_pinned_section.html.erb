<%# The "Starred" group: every favorited session on the current page, pinned above
    all category sections so the user's most important sessions are immediately visible.
    Rendered OUTSIDE the category drag-and-drop controller, so these cards are not
    draggable and the group is not a drop target — membership is driven purely by each
    session's `favorited` flag. The index star control reloads the page, so toggling a
    favorite from here rebuilds this group. A starred session appears only here, not in
    its category section. The section is omitted entirely when no sessions are starred. %>
<section class="mb-8" id="pinned_section">
  <div class="flex items-center gap-2 min-w-0 mb-3">
    <span class="text-yellow-500 shrink-0" aria-hidden="true">
      <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.957a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.367 2.446a1 1 0 00-.364 1.118l1.287 3.957c.3.922-.755 1.688-1.54 1.118l-3.366-2.446a1 1 0 00-1.175 0l-3.367 2.446c-.784.57-1.838-.197-1.539-1.118l1.286-3.957a1 1 0 00-.363-1.118L2.98 9.384c-.783-.57-.38-1.81.588-1.81h4.162a1 1 0 00.951-.69l1.286-3.957z" />
      </svg>
    </span>
    <h2 class="text-lg font-semibold text-gray-800 truncate">Starred</h2>
  </div>
  <div class="grid gap-6 grid-cols-[repeat(auto-fill,minmax(320px,400px))] justify-center">
    <% sessions.each do |session| %>
      <%= turbo_frame_tag dom_id(session) do %>
        <%= render "session_card", agent_session: session %>
      <% end %>
    <% end %>
  </div>
</section>
