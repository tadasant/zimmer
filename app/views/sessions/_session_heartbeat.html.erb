<%# Per-session heartbeat control: a heart icon (next to the favorite star) with %>
<%# a popout to configure the beat interval. Driven by heartbeat_controller.js. %>
<div class="relative inline-flex"
     data-controller="heartbeat"
     data-heartbeat-session-id-value="<%= agent_session.id %>"
     data-heartbeat-enabled-value="<%= agent_session.heartbeat_enabled? %>"
     data-heartbeat-interval-seconds-value="<%= agent_session.heartbeat_interval_seconds %>">
  <button type="button"
          data-heartbeat-target="button"
          data-action="heartbeat#toggle"
          class="inline-flex items-center justify-center w-10 h-10 rounded-full hover:bg-gray-100 transition-colors <%= agent_session.heartbeat_enabled? ? 'text-red-500' : 'text-gray-300 hover:text-red-500' %>"
          title="<%= agent_session.heartbeat_enabled? ? 'Heartbeat on — click to configure' : 'Heartbeat off — click to enable' %>"
          aria-label="<%= agent_session.heartbeat_enabled? ? 'Configure heartbeat' : 'Enable heartbeat' %>"
          aria-pressed="<%= agent_session.heartbeat_enabled?.to_s %>">
    <%# Solid heart when the heartbeat is active %>
    <svg data-heartbeat-target="filledIcon" class="h-5 w-5 <%= "hidden" unless agent_session.heartbeat_enabled? %>" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
      <path fill-rule="evenodd" d="M9.653 16.915l-.005-.003-.019-.01a20.759 20.759 0 01-1.162-.682 22.045 22.045 0 01-3.312-2.586C3.55 12.42 2 10.44 2 8.5 2 6.014 3.958 4 6.5 4c1.464 0 2.766.706 3.5 1.797A4.317 4.317 0 0113.5 4C16.042 4 18 6.014 18 8.5c0 1.94-1.55 3.92-3.155 5.134a22.045 22.045 0 01-3.312 2.586 20.755 20.755 0 01-1.162.682l-.019.01-.005.003h-.002a.739.739 0 01-.69.001l-.002-.001z" clip-rule="evenodd" />
    </svg>
    <%# Outline heart when the heartbeat is off %>
    <svg data-heartbeat-target="outlineIcon" class="h-5 w-5 <%= "hidden" if agent_session.heartbeat_enabled? %>" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
    </svg>
  </button>

  <%# Popout: interval configuration + on/off controls %>
  <div data-heartbeat-target="popover"
       class="hidden absolute right-0 top-11 z-30 w-64 rounded-lg border border-gray-200 bg-white shadow-lg p-4 text-left">
    <div class="flex items-center justify-between mb-1">
      <span class="text-sm font-semibold text-gray-900">Heartbeat</span>
      <span data-heartbeat-target="statusBadge"
            class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= agent_session.heartbeat_enabled? ? 'bg-red-100 text-red-700' : 'bg-gray-100 text-gray-500' %>">
        <%= agent_session.heartbeat_enabled? ? "On" : "Off" %>
      </span>
    </div>
    <p class="text-xs text-gray-500 mb-3">When on, a session waiting for input is nudged to keep working toward its goal on this cadence.</p>

    <label class="block text-xs font-medium text-gray-700 mb-1">Beat every</label>
    <select data-heartbeat-target="intervalSelect"
            data-action="change->heartbeat#changeInterval"
            class="w-full rounded-md border-gray-300 text-sm focus:border-red-500 focus:ring-red-500">
      <% Session::HEARTBEAT_INTERVAL_OPTIONS.each do |label, seconds| %>
        <option value="<%= seconds %>" <%= "selected" if seconds == agent_session.heartbeat_interval_seconds %>><%= label %></option>
      <% end %>
    </select>

    <div class="mt-3 flex items-center justify-between">
      <button type="button" data-heartbeat-target="enableButton" data-action="heartbeat#enable"
              class="text-xs font-medium text-red-600 hover:text-red-700 <%= "hidden" if agent_session.heartbeat_enabled? %>">
        Turn on
      </button>
      <button type="button" data-heartbeat-target="disableButton" data-action="heartbeat#disable"
              class="text-xs font-medium text-gray-600 hover:text-gray-800 <%= "hidden" unless agent_session.heartbeat_enabled? %>">
        Turn off
      </button>
      <span data-heartbeat-target="status" class="text-xs text-gray-400"></span>
    </div>
  </div>
</div>
