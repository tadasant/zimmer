              <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>
          <div class="flex-1 overflow-y-auto p-4">
            <%= render "sessions/mobile_catalog_skills", agent_session: @session %>
          </div>
        </div>
      </div>
    <% end %>
    <% if defined?(@catalog_hooks_for_select) %>
      <div data-modal-kind="hooks" class="hidden fixed inset-0 z-[60] bg-black/40 flex items-end">
        <div class="bg-white w-full rounded-t-2xl shadow-2xl max-h-[90vh] flex flex-col">
          <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
            <h3 class="text-base font-semibold text-gray-900">Modify Hooks</h3>
            <button type="button" data-action="click->joystick-menu#closeModal" class="p-2 -mr-2 text-gray-400 hover:text-gray-600" aria-label="Close">
              <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>
          <div class="flex-1 overflow-y-auto p-4">
            <%= render "sessions/mobile_catalog_hooks", agent_session: @session %>
          </div>
        </div>
      </div>
    <% end %>
    <% if defined?(@plugins_for_select) %>
      <div data-modal-kind="plugins" class="hidden fixed inset-0 z-[60] bg-black/40 flex items-end">
        <div class="bg-white w-full rounded-t-2xl shadow-2xl max-h-[90vh] flex flex-col">
          <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
            <h3 class="text-base font-semibold text-gray-900">Modify Plugins</h3>
            <button type="button" data-action="click->joystick-menu#closeModal" class="p-2 -mr-2 text-gray-400 hover:text-gray-600" aria-label="Close">
              <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>
          <div class="flex-1 overflow-y-auto p-4">
            <%= render "sessions/mobile_catalog_plugins", agent_session: @session %>
          </div>
        </div>
      </div>
    <% end %>
    <% if defined?(@goals_for_select) %>
      <div data-modal-kind="goal" class="hidden fixed inset-0 z-[60] bg-black/40 flex items-end">
        <div class="bg-white w-full rounded-t-2xl shadow-2xl max-h-[90vh] flex flex-col">
          <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
            <h3 class="text-base font-semibold text-gray-900">Modify Goal</h3>
            <button type="button" data-action="click->joystick-menu#closeModal" class="p-2 -mr-2 text-gray-400 hover:text-gray-600" aria-label="Close">
              <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>
          <div class="flex-1 overflow-y-auto p-4">
            <%= render "sessions/mobile_goal", agent_session: @session %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
