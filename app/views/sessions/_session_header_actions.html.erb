<%# Action buttons section - broadcast target for real-time updates %>
<%# This partial contains all action buttons that depend on session state %>
<div id="session_<%= agent_session.id %>_header_actions" class="flex gap-2 items-center">
  <!-- Favorite Star Button -->
  <%= link_to toggle_favorite_session_path(agent_session), data: { turbo_method: :patch }, class: "inline-flex items-center justify-center w-10 h-10 rounded-full hover:bg-gray-100 transition-colors #{agent_session.favorited? ? 'text-yellow-500' : 'text-gray-300 hover:text-yellow-500'}", title: agent_session.favorited? ? "Remove from favorites" : "Add to favorites", "aria-label" => agent_session.favorited? ? "Remove from favorites" : "Add to favorites", "aria-pressed" => agent_session.favorited?.to_s do %>
    <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
    </svg>
  <% end %>

  <!-- Heartbeat Toggle (heart icon + interval popout) -->
  <%= render "sessions/session_heartbeat", agent_session: agent_session %>

  <!-- Push Notifications Toggle (bell icon) -->
  <%# Per-session opt-in: when on, a state transition into needs_input or failed enqueues a push notification. %>
  <%= link_to toggle_push_notifications_session_path(agent_session),
      data: { turbo_method: :patch },
      class: "inline-flex items-center justify-center w-10 h-10 rounded-full hover:bg-gray-100 transition-colors #{agent_session.push_notifications_enabled? ? 'text-indigo-600' : 'text-gray-300 hover:text-indigo-600'}",
      title: agent_session.push_notifications_enabled? ? "Push notifications on for this session — click to disable" : "Push notifications off for this session — click to enable",
      "aria-label" => agent_session.push_notifications_enabled? ? "Disable push notifications for this session" : "Enable push notifications for this session",
      "aria-pressed" => agent_session.push_notifications_enabled?.to_s do %>
    <% if agent_session.push_notifications_enabled? %>
      <%# Solid bell when armed %>
      <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z" />
      </svg>
    <% else %>
      <%# Outline bell when off %>
      <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
      </svg>
    <% end %>
  <% end %>

  <!-- Copy Transcript Button (icon-only) -->
  <div data-controller="transcript-copy" data-transcript-copy-url-value="<%= transcript_session_path(agent_session, format: :text) %>">
    <button type="button"
            data-action="click->transcript-copy#copy"
            data-transcript-copy-target="button"
            class="inline-flex items-center justify-center w-10 h-10 rounded-full hover:bg-gray-100 transition-colors text-gray-500 hover:text-gray-700"
            title="Copy full transcript to clipboard"
            aria-label="Copy full transcript to clipboard">
      <svg data-transcript-copy-target="copyIcon" class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" />
      </svg>
      <svg data-transcript-copy-target="spinner" class="hidden animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      <svg data-transcript-copy-target="checkIcon" class="hidden h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
      </svg>
      <svg data-transcript-copy-target="errorIcon" class="hidden h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- GitHub PR Link -->
  <%= render "sessions/github_pr_link", agent_session: agent_session, size: :large %>

  <%# Use link_to with data-turbo-method instead of button_to to fix CSRF token issues %>
  <%# When partials are broadcast via Turbo Streams, button_to forms get stale/empty CSRF tokens %>
  <%# because they're rendered without an HTTP request context. link_to with data-turbo-method %>
  <%# reads the CSRF token from the page's meta tag on each request, avoiding this issue. %>

  <!-- Refresh Button -->
  <%= link_to refresh_session_path(agent_session), data: { turbo_method: :post }, class: "inline-flex items-center justify-center w-10 h-10 rounded-full hover:bg-gray-100 transition-colors text-gray-500 hover:text-gray-700", title: "Refresh transcript from filesystem", "aria-label" => "Refresh transcript from filesystem" do %>
    <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
      <path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd" />
    </svg>
  <% end %>

  <!-- Pause Button (only show when running) -->
  <% if agent_session.running? %>
    <%= link_to pause_session_path(agent_session), data: { turbo_method: :post }, class: "inline-flex items-center px-4 py-2 border border-yellow-300 text-sm font-medium rounded-md shadow-sm text-yellow-700 bg-yellow-50 hover:bg-yellow-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-yellow-500", title: "Pause session to send a follow-up prompt" do %>
      <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zM7 8a1 1 0 012 0v4a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v4a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
      </svg>
      <span class="ml-2">Pause</span>
    <% end %>
  <% end %>

  <!-- Restart Button (only show when failed) -->
  <% if agent_session.failed? %>
    <%= link_to restart_session_path(agent_session), data: { turbo_method: :post }, class: "inline-flex items-center px-4 py-2 border border-green-300 text-sm font-medium rounded-md shadow-sm text-green-700 bg-green-50 hover:bg-green-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500", title: "Restart failed session" do %>
      <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd" />
      </svg>
      <span class="ml-2">Restart</span>
    <% end %>
  <% end %>

  <% if agent_session.archived? %>
    <%= link_to unarchive_session_path(agent_session), data: { turbo_method: :post }, class: "inline-flex items-center px-4 py-2 border border-green-300 text-sm font-medium rounded-md shadow-sm text-green-700 bg-green-50 hover:bg-green-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" do %>
      <svg class="h-4 w-4 mr-1.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd" />
      </svg>
      Restore
    <% end %>
    <% if agent_session.trash_after.present? %>
      <span class="text-xs text-gray-500" title="Clone will be permanently deleted after this date">
        <% if agent_session.trash_after > Time.current %>
          Expires <%= distance_of_time_in_words(Time.current, agent_session.trash_after) %> from now
        <% else %>
          Clone deletion pending
        <% end %>
      </span>
    <% end %>
  <% else %>
    <div data-controller="archive-countdown"
         data-archive-countdown-session-id-value="<%= agent_session.id %>"
         data-archive-countdown-archive-url-value="<%= archive_session_path(agent_session) %>">
<%# session-drawer#close dismisses the drawer when archiving the session being
          viewed in it (the dashboard card behind is removed by the archive stream).
          It is a no-op outside the drawer — close() early-returns when not open and
          the controller is simply absent on the full-page detail view. %>
      <button type="button"
              data-action="click->archive-countdown#startCountdown click->session-drawer#close"
              data-archive-countdown-target="archiveButton"
              class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
              title="Move to trash (clone preserved for 7 days)">
        <svg class="h-4 w-4 mr-1.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
        </svg>
        Trash
      </button>
    </div>
  <% end %>
</div>
