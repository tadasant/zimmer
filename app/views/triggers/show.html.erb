<div class="min-h-screen bg-gray-50" data-controller="trigger-invoke">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="mb-8">
      <%= link_to triggers_path, class: "inline-flex items-center text-sm font-medium text-gray-500 hover:text-gray-700 mb-4" do %>
        <svg class="mr-2 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
        </svg>
        Back to Triggers
      <% end %>

      <div class="flex justify-between items-start">
        <div>
          <div class="flex items-center space-x-3">
            <h1 class="text-3xl font-bold text-gray-900"><%= @trigger.name %></h1>
            <% if @trigger.enabled? %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                Enabled
              </span>
            <% else %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                Disabled
              </span>
            <% end %>
            <% if @trigger.reuse_session %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">
                Re-uses session
              </span>
            <% end %>
            <% if @trigger.enqueue_messages %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
                Enqueues messages
              </span>
            <% end %>
            <% if @trigger.resuscitate_archived %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-800">
                Resuscitates archived
              </span>
            <% end %>
          </div>
          <p class="mt-2 text-sm text-gray-600">
            <%= @trigger.trigger_conditions.size %> condition<%= @trigger.trigger_conditions.size == 1 ? "" : "s" %>:
            <%= @trigger.conditions_summary %>
          </p>
        </div>

        <div class="flex items-center space-x-2">
          <button type="button" data-action="click->trigger-invoke#toggle" class="inline-flex items-center px-4 py-2 border border-indigo-300 text-sm font-medium rounded-md text-indigo-700 bg-indigo-50 hover:bg-indigo-100">
            <svg class="mr-1.5 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd" />
            </svg>
            Run Now
          </button>
          <%= button_to toggle_trigger_path(@trigger), method: :post, class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md #{@trigger.enabled? ? 'text-gray-700 bg-white hover:bg-gray-50' : 'text-green-700 bg-green-50 hover:bg-green-100'}" do %>
            <% if @trigger.enabled? %>
              Disable
            <% else %>
              Enable
            <% end %>
          <% end %>
          <%= link_to edit_trigger_path(@trigger), class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" do %>
            Edit
          <% end %>
          <%= button_to trigger_path(@trigger), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this trigger?" }, class: "inline-flex items-center px-4 py-2 border border-red-300 text-sm font-medium rounded-md text-red-700 bg-white hover:bg-red-50" do %>
            Delete
          <% end %>
        </div>
      </div>
    </div>

    <!-- Invoke Panel -->
    <div data-trigger-invoke-target="panel" class="hidden mb-6">
      <div class="bg-indigo-50 border border-indigo-200 shadow rounded-lg">
        <div class="px-6 py-4 border-b border-indigo-200">
          <div class="flex items-center justify-between">
            <h2 class="text-lg font-medium text-indigo-900">Run Trigger Manually</h2>
            <button type="button" data-action="click->trigger-invoke#toggle" class="text-indigo-400 hover:text-indigo-600">
              <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </button>
          </div>
          <p class="mt-1 text-sm text-indigo-700">Fire this trigger immediately, creating a new session with the prompt template.</p>
        </div>
        <div class="px-6 py-4">
          <%= form_with url: invoke_trigger_path(@trigger), method: :post, class: "space-y-4" do %>
            <% variables = @trigger.prompt_variables %>
            <% if variables.any? %>
              <p class="text-sm text-indigo-800 font-medium">
                This prompt template uses variables that are normally filled from external events.
                You can optionally provide values below, or leave them blank.
              </p>
              <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                <% variables.each do |var| %>
                  <div>
                    <label for="invoke_<%= var %>" class="block text-sm font-medium text-gray-700"><%= "{{#{var}}}" %></label>
                    <% if var == "text" %>
                      <textarea name="<%= var %>" id="invoke_<%= var %>" rows="2" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-3 py-2" placeholder="<%= variable_placeholder(var) %>"></textarea>
                    <% else %>
                      <input type="text" name="<%= var %>" id="invoke_<%= var %>" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-3 py-2" placeholder="<%= variable_placeholder(var) %>">
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="text-sm text-indigo-800">
                This prompt template has no event-specific variables. Click "Run" to fire the trigger with auto-populated <code class="bg-indigo-100 px-1 rounded">{{time}}</code> and <code class="bg-indigo-100 px-1 rounded">{{date}}</code> values.
              </p>
            <% end %>
            <div class="flex items-center justify-end space-x-3 pt-2">
              <button type="button" data-action="click->trigger-invoke#toggle" class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                Cancel
              </button>
              <button type="submit" data-trigger-invoke-target="submitButton" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                <svg class="mr-1.5 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd" />
                </svg>
                Run
              </button>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Details Card -->
    <div class="bg-white shadow rounded-lg mb-6">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-medium text-gray-900">Trigger Configuration</h2>
      </div>
      <div class="px-6 py-4 space-y-4">
        <!-- Stats -->
        <div class="grid grid-cols-3 gap-4">
          <div class="bg-gray-50 rounded-lg p-4">
            <dt class="text-sm font-medium text-gray-500">Sessions Created</dt>
            <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= @trigger.sessions_created_count %></dd>
          </div>
          <div class="bg-gray-50 rounded-lg p-4">
            <dt class="text-sm font-medium text-gray-500">Last Triggered</dt>
            <dd class="mt-1 text-sm text-gray-900">
              <%= @trigger.last_triggered_at ? time_ago_in_words(@trigger.last_triggered_at) + " ago" : "Never" %>
            </dd>
          </div>
          <div class="bg-gray-50 rounded-lg p-4">
            <dt class="text-sm font-medium text-gray-500">Conditions</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @trigger.trigger_conditions.size %> configured</dd>
          </div>
        </div>

        <!-- Conditions List -->
        <div>
          <h3 class="text-sm font-medium text-gray-500 mb-2">Trigger Conditions (OR logic)</h3>
          <div class="space-y-2">
            <% @trigger.trigger_conditions.each do |condition| %>
              <div class="flex items-center space-x-2 bg-gray-50 rounded-lg p-3">
                <% case condition.condition_type %>
                <% when "slack" %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-800">Slack</span>
                  <span class="text-sm text-gray-900"><%= condition.description.sub("Slack: ", "") %></span>
                <% when "schedule" %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">Schedule</span>
                  <span class="text-sm text-gray-900"><%= condition.schedule_description %></span>
                <% when "ao_event" %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-orange-100 text-orange-800">Zimmer Event</span>
                  <span class="text-sm text-gray-900">
                    <%= condition.ao_event_name&.titleize %>
                    <% if condition.session_scoped_ao_event? %>
                      <span class="text-gray-500">(session #<%= condition.watched_session_id %>)</span>
                    <% end %>
                  </span>
                <% when "github_label", "github_issue" %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-800 text-white">GitHub</span>
                  <span class="text-sm text-gray-900"><%= condition.description.sub("GitHub: ", "") %></span>
                <% else %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800"><%= condition.condition_type %></span>
                  <span class="text-sm text-gray-900"><%= condition.description %></span>
                <% end %>
                <% if condition.last_triggered_at %>
                  <span class="text-xs text-gray-400">(last: <%= time_ago_in_words(condition.last_triggered_at) %> ago)</span>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Configuration Details -->
        <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <dt class="text-sm font-medium text-gray-500">Agent Root</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @trigger.agent_root_name %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Session Re-use</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @trigger.reuse_session ? "Enabled" : "Disabled" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Enqueue Messages</dt>
            <dd class="mt-1 flex items-center space-x-2">
              <span class="text-sm text-gray-900"><%= @trigger.enqueue_messages ? "Enabled" : "Disabled" %></span>
              <% if @trigger.reuse_session %>
                <%= button_to toggle_enqueue_messages_trigger_path(@trigger), method: :post, class: "inline-flex items-center px-2 py-1 border border-gray-300 text-xs font-medium rounded-md #{@trigger.enqueue_messages ? 'text-gray-700 bg-white hover:bg-gray-50' : 'text-indigo-700 bg-indigo-50 hover:bg-indigo-100'}" do %>
                  <%= @trigger.enqueue_messages ? "Disable" : "Enable" %>
                <% end %>
              <% else %>
                <span class="text-xs text-gray-400">(requires re-use session)</span>
              <% end %>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Resuscitate Archived</dt>
            <dd class="mt-1 flex items-center space-x-2">
              <span class="text-sm text-gray-900"><%= @trigger.resuscitate_archived ? "Enabled" : "Disabled" %></span>
              <% if @trigger.reuse_session %>
                <%= button_to toggle_resuscitate_archived_trigger_path(@trigger), method: :post, class: "inline-flex items-center px-2 py-1 border border-gray-300 text-xs font-medium rounded-md #{@trigger.resuscitate_archived ? 'text-gray-700 bg-white hover:bg-gray-50' : 'text-teal-700 bg-teal-50 hover:bg-teal-100'}" do %>
                  <%= @trigger.resuscitate_archived ? "Disable" : "Enable" %>
                <% end %>
              <% else %>
                <span class="text-xs text-gray-400">(requires re-use session)</span>
              <% end %>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Max Sessions / Minute</dt>
            <dd class="mt-1 flex items-center space-x-2">
              <span class="text-sm text-gray-900">
                <%= @trigger.max_sessions_per_minute.presence || "No limit" %>
              </span>
              <% if @trigger.bursting? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800">
                  Bursting — spawns suppressed
                </span>
              <% end %>
            </dd>
          </div>
          <% if @trigger.mcp_servers.present? %>
            <div class="sm:col-span-2">
              <dt class="text-sm font-medium text-gray-500">MCP Servers</dt>
              <dd class="mt-1 flex flex-wrap gap-1">
                <% @trigger.mcp_servers.each do |server| %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-100 text-indigo-800">
                    <%= server %>
                  </span>
                <% end %>
              </dd>
            </div>
          <% end %>
          <% if @trigger.catalog_skills.present? %>
            <div class="sm:col-span-2">
              <dt class="text-sm font-medium text-gray-500">Skills</dt>
              <dd class="mt-1 flex flex-wrap gap-1">
                <% @trigger.catalog_skills.each do |skill_name| %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">
                    <%= skill_name %>
                  </span>
                <% end %>
              </dd>
            </div>
          <% end %>
          <% if @trigger.catalog_hooks.present? %>
            <div class="sm:col-span-2">
              <dt class="text-sm font-medium text-gray-500">Hooks</dt>
              <dd class="mt-1 flex flex-wrap gap-1">
                <% @trigger.catalog_hooks.each do |hook_name| %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-800">
                    <%= hook_name %>
                  </span>
                <% end %>
              </dd>
            </div>
          <% end %>
          <% if @trigger.catalog_plugins.present? %>
            <div class="sm:col-span-2">
              <dt class="text-sm font-medium text-gray-500">Plugins</dt>
              <dd class="mt-1 flex flex-wrap gap-1">
                <% @trigger.catalog_plugins.each do |plugin_id| %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-800">
                    <%= plugin_id %>
                  </span>
                <% end %>
              </dd>
            </div>
          <% end %>
          <% if @trigger.goal.present? %>
            <div class="sm:col-span-2">
              <dt class="text-sm font-medium text-gray-500">Goal</dt>
              <dd class="mt-1 text-sm text-gray-900 whitespace-pre-wrap"><%= @trigger.goal %></dd>
            </div>
          <% end %>
        </dl>
      </div>
    </div>

    <!-- Prompt Template Card -->
    <div class="bg-white shadow rounded-lg mb-6">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-medium text-gray-900">Prompt Template</h2>
        <p class="mt-1 text-sm text-gray-500">This prompt is sent to the agent when the trigger fires. Variables: <code class="bg-gray-100 px-1 rounded">{{link}}</code>, <code class="bg-gray-100 px-1 rounded">{{text}}</code>, <code class="bg-gray-100 px-1 rounded">{{author}}</code>, <code class="bg-gray-100 px-1 rounded">{{channel}}</code>, <code class="bg-gray-100 px-1 rounded">{{time}}</code>, <code class="bg-gray-100 px-1 rounded">{{date}}</code>, <code class="bg-gray-100 px-1 rounded">{{event}}</code></p>
      </div>
      <div class="px-6 py-4">
        <pre class="text-sm text-gray-800 whitespace-pre-wrap bg-gray-50 p-4 rounded-lg"><%= @trigger.prompt_template %></pre>
      </div>
    </div>

    <!-- Recent Sessions -->
    <div class="bg-white shadow rounded-lg">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-medium text-gray-900">Recent Sessions</h2>
        <p class="mt-1 text-sm text-gray-500">Sessions created by this trigger</p>
      </div>
      <% if @recent_sessions.empty? %>
        <div class="px-6 py-8 text-center text-gray-500">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
          <p class="mt-2">No sessions created yet</p>
          <p class="mt-1 text-sm">Sessions will appear here when the trigger fires</p>
        </div>
      <% else %>
        <ul class="divide-y divide-gray-200">
          <% @recent_sessions.each do |session| %>
            <li class="px-6 py-4 hover:bg-gray-50">
              <div class="flex items-center justify-between">
                <div>
                  <%= link_to session_path(session), class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" do %>
                    <%= session.title.presence || "Session ##{session.id}" %>
                  <% end %>
                  <p class="mt-1 text-sm text-gray-500">
                    Created <%= time_ago_in_words(session.created_at) %> ago
                  </p>
                </div>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                  <%= case session.status.to_s
                      when 'running' then 'bg-blue-100 text-blue-800'
                      when 'waiting' then 'bg-yellow-100 text-yellow-800'
                      when 'needs_input' then 'bg-orange-100 text-orange-800'
                      when 'archived' then 'bg-gray-100 text-gray-800'
                      when 'failed' then 'bg-red-100 text-red-800'
                      else 'bg-gray-100 text-gray-800'
                      end %>">
                  <%= session.status.to_s.titleize %>
                </span>
              </div>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>
  </div>
</div>
