<%# Individual enqueued message in accordion format with edit and copy support %>
<%= turbo_frame_tag dom_id(message) do %>
  <div class="bg-gray-50 border border-gray-200 rounded-md mb-2 transition-all"
       data-controller="enqueued-message-accordion enqueued-message-edit"
       data-enqueued-message-accordion-expanded-value="false"
       data-enqueued-message-edit-content-value="<%= message.content.to_json %>"
       data-enqueued-message-edit-goal-value="<%= (message.goal || '').to_json %>"
       data-enqueued-message-edit-update-url-value="<%= session_enqueued_message_path(message.session, message) %>"
       data-enqueued-messages-list-target="item"
       data-message-id="<%= message.id %>"
       data-action="dragstart->enqueued-messages-list#dragStart dragend->enqueued-messages-list#dragEnd dragover->enqueued-messages-list#dragOver dragleave->enqueued-messages-list#dragLeave drop->enqueued-messages-list#drop"
       draggable="true">

    <% if local_assigns[:error] %>
      <div class="px-3 pt-2">
        <div class="text-sm text-red-600 bg-red-50 border border-red-200 rounded px-3 py-2">
          <%= error %>
        </div>
      </div>
    <% end %>

    <!-- Collapsed view -->
    <div class="flex items-start gap-3 p-3">
      <!-- Drag handle -->
      <div class="flex-shrink-0 cursor-move text-gray-400 hover:text-gray-600 mt-1" title="Drag to reorder">
        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path d="M7 2a2 2 0 1 0 .001 4.001A2 2 0 0 0 7 2zm0 6a2 2 0 1 0 .001 4.001A2 2 0 0 0 7 8zm0 6a2 2 0 1 0 .001 4.001A2 2 0 0 0 7 14zm6-8a2 2 0 1 0-.001-4.001A2 2 0 0 0 13 6zm0 2a2 2 0 1 0 .001 4.001A2 2 0 0 0 13 8zm0 6a2 2 0 1 0 .001 4.001A2 2 0 0 0 13 14z"/>
        </svg>
      </div>

      <!-- Position badge -->
      <div class="flex-shrink-0 mt-1">
        <span class="inline-flex items-center justify-center h-6 w-6 rounded-full bg-indigo-100 text-indigo-800 text-xs font-semibold">
          <%= message.position %>
        </span>
      </div>

      <!-- Message content (truncated) -->
      <div class="flex-1 min-w-0">
        <button type="button"
                class="text-left w-full"
                data-action="click->enqueued-message-accordion#toggle"
                data-enqueued-message-accordion-target="toggleButton">
          <div class="flex items-center gap-2">
            <svg class="h-4 w-4 text-gray-500 transition-transform flex-shrink-0"
                 data-enqueued-message-accordion-target="chevron"
                 xmlns="http://www.w3.org/2000/svg"
                 viewBox="0 0 20 20"
                 fill="currentColor">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
            <p class="text-sm text-gray-700 truncate">
              <%= truncate(message.content, length: 100) %>
            </p>
          </div>
        </button>

        <!-- Full content (expanded) - View Mode -->
        <div class="hidden mt-3 pl-6" data-enqueued-message-accordion-target="content">
          <!-- View Mode -->
          <div data-enqueued-message-edit-target="viewMode">
            <div class="prose prose-sm max-w-none">
              <div class="bg-white rounded border border-gray-200 p-3 mb-3 relative group">
                <p class="text-sm text-gray-900 whitespace-pre-wrap pr-8"><%= message.content %></p>
                <!-- Copy button in top right corner -->
                <button type="button"
                        class="absolute top-2 right-2 p-1.5 text-gray-400 hover:text-gray-600 rounded hover:bg-gray-100 transition-colors"
                        data-action="click->enqueued-message-edit#copy"
                        data-enqueued-message-edit-target="copyButton"
                        aria-label="Copy message to clipboard"
                        title="Copy to clipboard">
                  <!-- Copy icon -->
                  <svg data-enqueued-message-edit-target="copyIcon" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                  </svg>
                  <!-- Check icon (shown after copy) -->
                  <svg data-enqueued-message-edit-target="checkIcon" class="h-4 w-4 hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </button>
              </div>
              <% if message.goal.present? %>
                <div class="bg-white rounded border border-gray-200 p-3">
                  <p class="text-xs font-medium text-gray-700 mb-1">Goal:</p>
                  <p class="text-sm text-gray-600 font-mono whitespace-pre-wrap"><%= message.goal %></p>
                </div>
              <% end %>
            </div>
            <!-- Edit button -->
            <div class="mt-3">
              <button type="button"
                      class="inline-flex items-center px-2.5 py-1.5 border border-gray-300 text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
                      data-action="click->enqueued-message-edit#edit"
                      title="Edit message">
                <svg class="h-3.5 w-3.5 mr-1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
                </svg>
                Edit
              </button>
            </div>
          </div>

          <!-- Edit Mode -->
          <div class="hidden" data-enqueued-message-edit-target="editMode">
            <div class="space-y-3">
              <div>
                <label class="block text-xs font-medium text-gray-700 mb-1">Message Content</label>
                <textarea
                  class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                  rows="4"
                  data-enqueued-message-edit-target="contentTextarea"
                ><%= message.content %></textarea>
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-700 mb-1">Goal (optional)</label>
                <textarea
                  class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 font-mono"
                  rows="2"
                  data-enqueued-message-edit-target="goalTextarea"
                ><%= message.goal %></textarea>
              </div>
              <div class="flex gap-2">
                <button type="button"
                        class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
                        data-action="click->enqueued-message-edit#save"
                        data-enqueued-message-edit-target="saveButton">
                  Save
                </button>
                <button type="button"
                        class="inline-flex items-center px-3 py-1.5 border border-gray-300 text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
                        data-action="click->enqueued-message-edit#cancel">
                  Cancel
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Action buttons -->
      <div class="flex items-start gap-2 flex-shrink-0">
        <!-- Interrupt button (send immediately) -->
        <%= button_to interrupt_session_enqueued_message_path(message.session, message),
              method: :post,
              form: { data: { turbo_frame: "_top" } },
              class: "inline-flex items-center px-2.5 py-1.5 border border-transparent text-xs font-medium rounded text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500",
              title: "Send this message now (pauses agent)" do %>
          <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z" />
          </svg>
          <span class="ml-1">Send Now</span>
        <% end %>

        <!-- Delete button -->
        <%= button_to session_enqueued_message_path(message.session, message),
              method: :delete,
              form: { data: { turbo_confirm: "Delete this enqueued message?", turbo_frame: "_top" } },
              class: "inline-flex items-center p-1.5 border border-gray-300 rounded text-gray-700 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500",
              title: "Delete message" do %>
          <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
