---
import Default from "@astrojs/starlight/components/Head.astro";
---

<Default><slot /></Default>

<script>
  import mermaid from "mermaid";

  // Diagrams are rendered client-side rather than baked to SVG at build time.
  // Static prerendering (rehype-mermaid) would need a headless Chromium in CI
  // and would still commit us to a single colour scheme; rendering in the
  // browser lets a diagram re-theme when the reader flips light/dark.
  const THEMES = { light: "default", dark: "dark" } as const;

  function currentTheme(): keyof typeof THEMES {
    return document.documentElement.dataset.theme === "dark" ? "dark" : "light";
  }

  let rendering = false;

  async function renderAll() {
    const nodes = Array.from(
      document.querySelectorAll<HTMLElement>(".mermaid-diagram"),
    );
    if (nodes.length === 0 || rendering) return;
    rendering = true;

    const dark = currentTheme() === "dark";
    mermaid.initialize({
      startOnLoad: false,
      theme: THEMES[currentTheme()],
      // Paint the diagrams in Zimmer's own palette rather than stock Mermaid, and
      // give the nodes enough fill contrast to sit above the figure panel. The
      // accent border ties every diagram back to the logo.
      themeVariables: dark
        ? {
            primaryColor: "#1a2340",
            mainBkg: "#1a2340",
            primaryBorderColor: "#5a6bd8",
            nodeBorder: "#5a6bd8",
            primaryTextColor: "#eceef2",
            lineColor: "#8b90a0",
            secondaryColor: "#24314f",
            tertiaryColor: "#20222b",
            clusterBkg: "#20222b",
            clusterBorder: "#3a3d47",
            edgeLabelBackground: "#20222b",
            titleColor: "#eceef2",
          }
        : {
            primaryColor: "#e5e9fb",
            mainBkg: "#e5e9fb",
            primaryBorderColor: "#3b4bc0",
            nodeBorder: "#3b4bc0",
            primaryTextColor: "#1e2456",
            lineColor: "#545861",
            secondaryColor: "#d5daf7",
            tertiaryColor: "#f2f3f8",
            clusterBkg: "#f2f3f8",
            clusterBorder: "#c0c2c7",
            edgeLabelBackground: "#f2f3f8",
            titleColor: "#1e2456",
          },
      securityLevel: "strict",
      fontFamily:
        '"IBM Plex Sans Variable", system-ui, sans-serif',
      flowchart: { curve: "basis", useMaxWidth: true },
      sequence: { useMaxWidth: true },
    });

    for (const [i, node] of nodes.entries()) {
      const encoded = node.dataset.mermaid;
      if (!encoded) continue;
      const source = new TextDecoder().decode(
        Uint8Array.from(atob(encoded), (c) => c.charCodeAt(0)),
      );
      try {
        const { svg } = await mermaid.render(`mermaid-${i}-${Date.now()}`, source);
        node.innerHTML = svg;
        node.dataset.rendered = "true";
      } catch (error) {
        node.innerHTML = `<pre class="mermaid-error">Diagram failed to render:\n${
          error instanceof Error ? error.message : String(error)
        }</pre>`;
      }
    }

    rendering = false;
  }

  renderAll();
  document.addEventListener("astro:page-load", renderAll);

  // Starlight's theme switcher flips data-theme on <html>; re-render so the
  // diagram's palette follows the page instead of staying stuck on the scheme
  // that happened to be active at first paint.
  new MutationObserver((records) => {
    if (records.some((r) => r.attributeName === "data-theme")) {
      document
        .querySelectorAll<HTMLElement>(".mermaid-diagram")
        .forEach((node) => delete node.dataset.rendered);
      renderAll();
    }
  }).observe(document.documentElement, { attributes: true });

  // Clicking a heading's anchor link copies its deep link to the clipboard and
  // updates the URL hash. On success the link icon is swapped for a checkmark
  // for ~1.4s (no overlapping text; Starlight's icon centering is reused).
  const CHECK_SVG =
    '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>';

  document.addEventListener("click", (event) => {
    const e = event as MouseEvent;
    // Let modified / non-left clicks behave normally (open in new tab, etc.).
    if (e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;

    const link = (event.target as HTMLElement)?.closest?.(
      "a.sl-anchor-link",
    ) as HTMLAnchorElement | null;
    if (!link) return;
    event.preventDefault();

    const hash = new URL(link.href).hash;
    const url = location.origin + location.pathname + location.search + hash;
    history.pushState(null, "", hash);

    const iconHost = link.querySelector<HTMLElement>(".sl-anchor-icon");
    // Only confirm (swap to checkmark) when the write actually succeeded.
    const confirm = () => {
      if (!iconHost || link.hasAttribute("data-copied")) return;
      const original = iconHost.innerHTML;
      iconHost.innerHTML = CHECK_SVG;
      link.setAttribute("data-copied", "");
      window.setTimeout(() => {
        iconHost.innerHTML = original;
        link.removeAttribute("data-copied");
      }, 1400);
    };
    navigator.clipboard?.writeText?.(url).then(confirm, () => {});
  });

  // ---- Image / diagram lightbox --------------------------------------------
  // Click any diagram or content image to view it full-screen; Esc / backdrop /
  // the close button dismisses it.
  const lightbox = document.createElement("div");
  lightbox.className = "lightbox";
  lightbox.setAttribute("role", "dialog");
  lightbox.setAttribute("aria-modal", "true");
  lightbox.setAttribute("aria-label", "Enlarged view");
  lightbox.innerHTML =
    '<button class="lightbox-close" aria-label="Close">✕</button><div class="lightbox-stage"></div>';
  const stage = lightbox.querySelector<HTMLElement>(".lightbox-stage")!;
  document.body.appendChild(lightbox);

  function openLightbox(node: SVGElement | HTMLImageElement) {
    stage.replaceChildren(node);
    lightbox.classList.add("open");
    document.body.style.overflow = "hidden";
  }
  function closeLightbox() {
    lightbox.classList.remove("open");
    stage.replaceChildren();
    document.body.style.overflow = "";
  }

  lightbox.addEventListener("click", (event) => {
    // Backdrop or close button closes; clicking the image itself does not.
    if (
      event.target === lightbox ||
      (event.target as HTMLElement).closest(".lightbox-close")
    ) {
      closeLightbox();
    }
  });
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && lightbox.classList.contains("open")) closeLightbox();
  });

  document.addEventListener("click", (event) => {
    const el = event.target as HTMLElement;
    if (el.closest(".lightbox")) return;

    const figure = el.closest(".mermaid-figure");
    if (figure) {
      const svg = figure.querySelector("svg");
      if (svg) {
        const clone = svg.cloneNode(true) as SVGElement;
        clone.removeAttribute("style"); // drop Mermaid's max-width cap

        // An SVG with a viewBox but no explicit size collapses, so size it to
        // "contain" the viewport (as large as fits, preserving aspect ratio).
        const vb = svg.viewBox?.baseVal;
        const vbW = vb && vb.width ? vb.width : svg.getBoundingClientRect().width || 800;
        const vbH = vb && vb.height ? vb.height : svg.getBoundingClientRect().height || 600;
        const avW = window.innerWidth * 0.9;
        const avH = window.innerHeight * 0.86;
        const scale = Math.min(avW / vbW, avH / vbH);
        clone.style.width = Math.round(vbW * scale) + "px";
        clone.style.height = Math.round(vbH * scale) + "px";
        clone.style.maxWidth = "none";
        clone.style.maxHeight = "none";

        openLightbox(clone);
      }
      return;
    }

    const img = el.closest(".sl-markdown-content img") as HTMLImageElement | null;
    if (img) {
      const clone = new Image();
      clone.src = img.currentSrc || img.src;
      clone.alt = img.alt;
      openLightbox(clone);
    }
  });
</script>
